<?xml version="1.0"?>
<configuration>
  <connectionStrings>
    <add name="PathlabDB" connectionString="Data Source=DESKTOP-KU06BHL;Initial Catalog=PathlabDB;Persist Security Info=True;User ID=sa;Password=bws;MultipleActiveResultSets=True" providerName="System.Data.SqlClient"/>
  </connectionStrings>
  <appSettings>
    <add key="WcfServiceUrl" value="http://localhost:2091/PathlabService.svc"/>
    <!-- Public site origin (e.g. https://portal.swapnildiagnostics.com), used only
         to build the doctor-share email link (ShareReportWithDoctor). Empty =
         the email still sends, but tells the doctor to ask the patient to re-share
         once this is set, instead of guessing/breaking a relative link. -->
    <add key="PortalBaseUrl" value="http://217.154.57.92/PathLab/Frontend"/>
    <add key="Fast2SmsApiKey" value=""/>
    <!-- LIMS integration: set LimsBaseUrl (e.g. https://labsols.com/LIMS-Pathology) to enable
         collection-job push on booking. Empty = jobs stay in LimsSyncStatus 'Pending'. -->
    <add key="LimsBaseUrl" value=""/>
    <add key="LimsApiKey" value=""/>
    <!-- GST invoicing (Billing Phase 2): used by MaybeGenerateInvoice + CreateBooking's
         GST calc. DefaultGstRate is a decimal fraction (0.18 = 18%); diagnostic/health
         services are commonly GST-exempt, so set to 0 where that applies. -->
    <add key="DefaultGstRate" value="0.18"/>
    <add key="CompanyGSTIN" value=""/>
    <add key="CompanyPlaceOfSupply" value=""/>
    <add key="DefaultHsnCode" value="9993"/>
    <!-- SMTP for doctor report-sharing emails (Report Delivery Phase 3). Empty
         SmtpHost = every send is skipped (logged, not faked) — see EmailHelper. -->
    <add key="SmtpHost" value=""/>
    <add key="SmtpPort" value="587"/>
    <add key="SmtpUser" value=""/>
    <add key="SmtpPassword" value=""/>
    <add key="SmtpFromAddress" value=""/>
    <!-- Partner/EHR-facing read APIs (Test Catalogue + Report Delivery Phase 4):
         GetPublicCatalogue / GetReportsApi require header "X-Api-Key" to match
         this value. Empty = both endpoints refuse every request (fail closed). -->
    <add key="PartnerApiKey" value=""/>
    <!-- WhatsApp Business Cloud API (Meta Graph API) — real automatic sends for
         BookingConfirmation/ReportReady/StatusUpdate, not just the existing
         manual wa.me share links. Get WhatsAppApiToken + WhatsAppPhoneNumberId
         from Meta Business Manager. Each event type needs its own pre-approved
         message template (business-initiated messages can't be free-form text) —
         set its name per type below. Empty = every send is skipped and logged,
         never faked. See WhatsAppHelper.cs. -->
    <add key="WhatsAppApiToken" value=""/>
    <add key="WhatsAppPhoneNumberId" value=""/>
    <add key="WhatsAppApiVersion" value="v19.0"/>
    <add key="WhatsAppLanguageCode" value="en"/>
    <add key="WhatsAppCountryCode" value="91"/>
    <add key="WhatsAppTemplate_BookingConfirmation" value=""/>
    <add key="WhatsAppTemplate_StatusUpdate" value=""/>
    <add key="WhatsAppTemplate_ReportReady" value=""/>
  </appSettings>
  <!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
  <system.web>
    <compilation debug="true" targetFramework="4.8"/>
    <httpRuntime targetFramework="4.5"/>
  </system.web>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- BCrypt.Net-Next compiles against Unsafe 4.0.4.1; the copy shipped in
           packages/ is 6.0.0.0 — redirect so PasswordHelper can load it. -->
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <system.serviceModel>
    <services>
      <service name="PathlabWcfService.PathlabService" behaviorConfiguration="PathlabServiceBehavior">
        <endpoint address="" binding="webHttpBinding" contract="PathlabWcfService.IPathlabService" behaviorConfiguration="webBehavior"/>
        <endpoint address="mex" binding="mexHttpBinding" contract="IMetadataExchange"/>
      </service>
    </services>
    <behaviors>
      <serviceBehaviors>
        <behavior name="PathlabServiceBehavior">
          <serviceMetadata httpGetEnabled="true" httpsGetEnabled="true"/>
          <serviceDebug includeExceptionDetailInFaults="true"/>
        </behavior>
      </serviceBehaviors>
      <endpointBehaviors>
        <behavior name="webBehavior">
          <webHttp defaultOutgoingResponseFormat="Json"/>
        </behavior>
      </endpointBehaviors>
    </behaviors>
    <!-- Dev-machine workaround for "Memory gates checking failed" — WCF refuses to
         activate a service when free system RAM drops below ~5%. Disabling this
         check locally is safe; a low-memory production host should get more RAM
         instead of relying on this setting. -->
    <serviceHostingEnvironment aspNetCompatibilityEnabled="true" multipleSiteBindingsEnabled="true" minFreeMemoryPercentageToActivateService="0"/>
  </system.serviceModel>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear/>
        <add value="PathlabService.svc"/>
      </files>
    </defaultDocument>
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*"/>
        <add name="Access-Control-Allow-Headers" value="Content-Type, Accept, X-Api-Key"/>
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS"/>
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
@{
    ViewBag.Title = "Book a Test";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
.sd-test-wrap{max-width:1100px;margin:30px auto;padding:0 16px;display:flex;gap:24px;align-items:flex-start}
.sd-test-panel{flex:1;background:#fff;border:1px solid #e8e0f0;border-radius:16px;padding:24px}
.sd-search-bar{display:flex;gap:10px;margin-bottom:20px}
.sd-search-bar input{flex:1;padding:12px 16px;border:1px solid #ddd;border-radius:8px;font-size:15px;font-family:inherit}
.sd-search-bar input:focus{border-color:#632c76;outline:none}
.sd-test-card{border:1px solid #f0e8ff;border-radius:12px;padding:16px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;gap:12px}
.sd-test-card:hover{border-color:#632c76;background:#faf5ff}
.sd-test-name{font-size:15px;font-weight:600;color:#222}
.sd-test-meta{font-size:12px;color:#888;margin-top:3px}
.sd-test-price{font-size:17px;font-weight:700;color:#632c76;white-space:nowrap}
.sd-add-btn{background:#632c76;color:#fff;border:none;border-radius:35px 0 35px 35px;padding:9px 20px;cursor:pointer;font-size:13px;font-weight:600;transition:background .3s}
.sd-add-btn:hover{background:#1253be}
.sd-add-btn.added{background:#51ca62}
.sd-cart-panel{width:320px;background:#fff;border:1px solid #e8e0f0;border-radius:16px;padding:24px;position:sticky;top:20px}
.sd-cart-panel h3{color:#632c76;font-size:18px;margin-bottom:16px}
.sd-cart-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #f5f0fa;gap:8px}
.sd-cart-item-name{font-size:14px;font-weight:600}
.sd-cart-item-price{color:#632c76;font-weight:700;font-size:14px}
.sd-remove-btn{background:none;border:none;color:#e53e3e;cursor:pointer;font-size:16px}
.sd-cart-total{background:#f8f5fc;border-radius:10px;padding:14px;margin-top:12px}
.sd-checkout-btn{display:block;width:100%;padding:15px;background:#632c76;color:#fff;border:none;border-radius:35px 0 35px 35px;font-size:16px;font-weight:700;cursor:pointer;margin-top:14px;transition:background .3s}
.sd-checkout-btn:hover{background:#1253be}
.sd-empty-cart{text-align:center;color:#aaa;padding:30px 0;font-size:14px}
.sd-cat-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.sd-cat-tab{padding:6px 16px;border:1px solid #ddd;border-radius:20px;cursor:pointer;font-size:13px;background:#fff}
.sd-cat-tab.active{background:#632c76;color:#fff;border-color:#632c76}
.sd-toast{position:fixed;bottom:24px;right:24px;z-index:99999;background:#632c76;color:#fff;padding:12px 22px;border-radius:10px;font-size:14px;font-weight:500;transform:translateY(100px);opacity:0;transition:all .35s ease;pointer-events:none}
.sd-toast.show{transform:translateY(0);opacity:1}
.sd-toast.success{background:#2e7d32}
</style>
}

<div data-ng-controller="BookTestController">

<div style="background:linear-gradient(135deg,#4a1060,#632c76);padding:28px 0;color:#fff;margin-bottom:0">
    <div style="max-width:1100px;margin:0 auto;padding:0 16px">
        <h1 style="font-size:22px;font-weight:700;margin-bottom:4px"><i class="fa fa-flask"></i>&nbsp; Book a Lab Test</h1>
        <p style="opacity:.85;font-size:14px;margin:0">Search and add tests. Proceed to checkout when ready.</p>
    </div>
</div>

<div class="sd-test-wrap">

    <!-- Tests Panel -->
    <div class="sd-test-panel">

        <!-- Single Test Suite dropdown -->
        <div style="margin-bottom:20px">
            <label style="display:block;font-weight:700;color:#632c76;font-size:14px;margin-bottom:8px"><i class="fa fa-list"></i> Select Test Suite</label>
            <select style="width:100%;padding:12px 14px;border:1.5px solid #ddd;border-radius:8px;font-size:15px;font-family:inherit;background:#fff"
                    data-ng-model="selectedSuiteId"
                    data-ng-options="t.TestSuiteID as (t.TestSuiteName + ' — ₹' + t.Price) for t in allTests">
                <option value="">-- Select Test Suite --</option>
            </select>
            <div data-ng-show="selectedSuite()" style="border:1.5px solid #632c76;border-radius:12px;padding:18px;margin-top:12px;background:#faf5ff">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap">
                    <div>
                        <div style="font-size:17px;font-weight:700;color:#222">{{selectedSuite().TestSuiteName}}</div>
                        <div style="font-size:13px;color:#666;margin-top:8px;line-height:2">
                            <i class="fa fa-tint" style="color:#632c76"></i> Sample: <strong>{{selectedSuite().SampleType}}</strong><br>
                            <i class="fa fa-flask" style="color:#632c76"></i> Includes: <strong>{{selectedSuite().TestCount}} test parameter(s)</strong><br>
                            <i class="fa fa-clock-o" style="color:#632c76"></i> Report: <strong>{{selectedSuite().ReportTime || '24–48 hours'}}</strong><br>
                            <i class="fa fa-cutlery" style="color:#632c76"></i> Fasting:
                            <strong data-ng-show="selectedSuite().FastingRequired" style="color:#e67e22">Required (8–12 hours)</strong>
                            <strong data-ng-hide="selectedSuite().FastingRequired" style="color:#2e7d32">Not required</strong>
                        </div>
                    </div>
                    <div style="text-align:right">
                        <div class="sd-test-price" style="font-size:22px">&#8377;{{selectedSuite().Price}}</div>
                        <button class="sd-add-btn" style="margin-top:10px" data-ng-class="{added: isInCart(selectedSuite())}" data-ng-click="toggleCart(selectedSuite())">
                            <i class="fa" data-ng-class="isInCart(selectedSuite()) ? 'fa-check' : 'fa-cart-plus'"></i>
                            {{isInCart(selectedSuite()) ? 'Added to Cart' : 'Add to Cart'}}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div style="font-size:12px;color:#aaa;text-transform:uppercase;letter-spacing:.5px;font-weight:700;margin-bottom:10px">Or browse all tests</div>
        <div class="sd-search-bar">
            <input type="text" placeholder="Search test name..." data-ng-model="searchQuery" data-ng-keyup="filterTests()">
        </div>
        <div class="sd-cat-tabs">
            <span class="sd-cat-tab" data-ng-class="{active: activeCategory==''}" data-ng-click="setCategory('')">All</span>
            <span class="sd-cat-tab" data-ng-repeat="cat in categories" data-ng-class="{active: activeCategory==cat}" data-ng-click="setCategory(cat)">{{cat}}</span>
        </div>
        <div data-ng-show="isLoading" style="text-align:center;padding:40px;color:#632c76">
            <i class="fa fa-spinner fa-spin fa-2x"></i><p>Loading tests...</p>
        </div>
        <div data-ng-repeat="t in filteredTests">
            <div class="sd-test-card">
                <div style="flex:1">
                    <div class="sd-test-name">{{t.TestSuiteName}}</div>
                    <div class="sd-test-meta"><i class="fa fa-tint"></i> {{t.SampleType}} &nbsp;|&nbsp; <i class="fa fa-clock-o"></i> {{t.ReportTime}} &nbsp;|&nbsp; {{t.TestCount}} parameters<span data-ng-show="t.FastingRequired" style="color:#e67e22"> &nbsp;|&nbsp; <i class="fa fa-cutlery"></i> Fasting required</span></div>
                </div>
                <div style="text-align:right">
                    <div class="sd-test-price">&#8377;{{t.Price}}</div>
                    <button class="sd-add-btn" data-ng-class="{added: isInCart(t)}" data-ng-click="toggleCart(t)">
                        <i class="fa" data-ng-class="isInCart(t) ? 'fa-check' : 'fa-plus'"></i>
                        {{isInCart(t) ? 'Added' : 'Add'}}
                    </button>
                </div>
            </div>
        </div>
        <div data-ng-show="!isLoading && filteredTests.length==0" style="text-align:center;padding:40px;color:#aaa">
            <i class="fa fa-search fa-2x"></i><p>No tests found</p>
        </div>
    </div>

    <!-- Cart Panel -->
    <div class="sd-cart-panel">
        <h3><i class="fa fa-shopping-cart"></i> Your Cart</h3>
        <!-- Saved cart (Cart & Checkout Phase 4) — survives a device switch -->
        <div data-ng-show="savedCartAvailable" style="background:#f8f5fc;border-radius:10px;padding:12px;margin-bottom:14px;font-size:13px">
            <div style="color:#555;margin-bottom:8px">You have a cart saved from another session.</div>
            <button class="sd-add-btn" style="width:100%" data-ng-click="restoreSavedCart()">Restore Saved Cart</button>
        </div>
        <div data-ng-show="cart.length==0" class="sd-empty-cart">
            <i class="fa fa-shopping-cart fa-2x" style="display:block;margin-bottom:8px;color:#ddd"></i>
            No tests added yet
        </div>
        <div data-ng-repeat="item in cart" class="sd-cart-item">
            <div>
                <div class="sd-cart-item-name">{{item.TestSuiteName}}</div>
                <div style="font-size:12px;color:#888">{{item.SampleType}}</div>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
                <span class="sd-cart-item-price">&#8377;{{item.Price}}</span>
                <button class="sd-remove-btn" data-ng-click="removeFromCart(item)"><i class="fa fa-times"></i></button>
            </div>
        </div>
        <div class="sd-cart-total" data-ng-show="cart.length>0">
            <div style="display:flex;justify-content:space-between;font-size:14px;color:#555;margin-bottom:6px">
                <span>Subtotal</span><span>&#8377;{{cartSubtotal()}}</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:14px;color:#555;margin-bottom:6px">
                <span>GST (18%)</span><span>&#8377;{{cartGst()}}</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:16px;font-weight:700;color:#632c76;border-top:1px solid #ddd;padding-top:8px;margin-top:4px">
                <span>Total</span><span>&#8377;{{cartTotal()}}</span>
            </div>
        </div>
        <button class="sd-checkout-btn" data-ng-show="cart.length>0" data-ng-click="proceedCheckout()">
            <i class="fa fa-lock"></i>&nbsp; Proceed to Checkout
        </button>
        <button style="background:none;border:none;color:#632c76;font-size:12px;cursor:pointer;width:100%;margin-top:8px;text-decoration:underline"
                data-ng-show="cart.length>0" data-ng-click="saveCartForLater()">
            Save cart for later
        </button>
    </div>

</div>

<div class="sd-toast" id="sdToast"></div>

</div><!-- end ng-controller -->

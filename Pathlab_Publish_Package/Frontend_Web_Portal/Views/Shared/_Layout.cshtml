    </div>
    <div class="side-bar-box">
        <a href="@Url.Action("CentreLocator","Company")"><img src="@Url.Content("~/images/map-mark.png")"><p>Centre / Lab Locator</p></a>
    </div>
    <div class="side-bar-box" style="cursor:pointer" onclick="window.location.href='@Url.Action("Portal","Patient")?tab=reports'">
        <img src="@Url.Content("~/images/report.png")"><p>Download Reports</p>
    </div>
    <div class="side-bar-box" style="cursor:pointer" onclick="window.location.href='@Url.Action("TrackSample","Patient")'">
        <img src="@Url.Content("~/images/report.png")"><p>Track Your Sample</p>
    </div>
</div>


<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <title>@ViewBag.Title - PATHLAB Diagnostics</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
    @{
        // Cache-buster tied to each file's actual last-write time: these files
        // (unlike the CDN/vendor libs below) are directly linked with no build
        // step or bundling, so browsers happily cache a stale copy forever
        // otherwise — every edit needs a fresh URL to guarantee it's picked up.
        Func<string, string> v = path => Url.Content(path) + "?v=" + System.IO.File.GetLastWriteTime(Server.MapPath(path)).Ticks;
    }
    <link href="@v("~/Content/style.css")" rel="stylesheet" type="text/css">
    <link href="@Url.Content("~/Content/slick.css")" rel="stylesheet" type="text/css">
    <link href="@Url.Content("~/Content/slick-theme.css")" rel="stylesheet" type="text/css">
    <link href="@v("~/Content/responsive.css")" rel="stylesheet" type="text/css">
    <script>var APP_ROOT = '@Url.Content("~/")';</script>
    <script>var WCF_SERVICE_URL = '@System.Configuration.ConfigurationManager.AppSettings["WcfServiceUrl"]';</script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js"></script>
    <script src="@Url.Content("~/Scripts/angular.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/angular-route.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/angularjs/Module.js")" type="text/javascript"></script>
    <script src="@v("~/Scripts/angularjs/Service.js")" type="text/javascript"></script>
    <script src="@v("~/Scripts/angularjs/Controller.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/slick.js")" type="text/javascript"></script>
    @RenderSection("styles", required: false)
</head>
<body data-ng-app="PathlabModule">


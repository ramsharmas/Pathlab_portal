@{
    ViewBag.Title = "Choose Collection";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
.cc-wrap{max-width:860px;margin:40px auto 64px;padding:0 20px}
.cc-breadcrumb{margin-bottom:24px;font-size:13px;color:#888}
.cc-breadcrumb a{color:#632c76;text-decoration:none}
.cc-breadcrumb a:hover{text-decoration:underline}
.cc-heading{font-size:28px;font-weight:700;color:#632c76;margin-bottom:8px;display:flex;align-items:center;gap:10px}
.cc-subheading{font-size:14px;color:#888;margin-bottom:28px}
.cc-toggle-row{display:flex;gap:16px;margin-bottom:28px;flex-wrap:wrap}
.cc-type-card{flex:1;min-width:220px;border:2px solid #ddd;border-radius:16px;padding:24px 22px;cursor:pointer;transition:all .25s;background:#fafafa;display:flex;align-items:flex-start;gap:16px}
.cc-type-card:hover{border-color:#632c76;background:#f5f0fa}
.cc-type-card.active{border-color:#632c76;background:#f5f0fa;box-shadow:0 0 0 3px rgba(99,44,118,.15)}
.cc-type-icon{width:48px;height:48px;border-radius:12px;background:#f0e8f8;display:flex;align-items:center;justify-content:center;font-size:22px;color:#632c76;flex-shrink:0}
.cc-type-card.active .cc-type-icon{background:#632c76;color:#fff}
.cc-type-title{font-size:16px;font-weight:700;color:#222;margin-bottom:4px}
.cc-type-desc{font-size:13px;color:#888}
.cc-panel{display:none}
.cc-panel.active{display:block}
.cc-card{background:#fff;border:1px solid #e8e0f0;border-radius:16px;padding:28px 32px;box-shadow:0 2px 12px rgba(99,44,118,.06);margin-bottom:20px}
.cc-card h3{font-size:17px;color:#632c76;margin-bottom:18px;display:flex;align-items:center;gap:8px}
.cc-form-row{margin-bottom:16px}
.cc-form-row label{display:block;font-size:12px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.cc-form-row select,.cc-form-row input{width:100%;padding:13px 15px;border:1.5px solid #ddd;border-radius:10px;font-size:15px;color:#222;font-family:inherit;background:#fafafa;transition:border-color .2s;box-sizing:border-box}
.cc-form-row select:focus,.cc-form-row input:focus{border-color:#632c76;outline:none;background:#fff}
.cc-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.cc-slots-label{font-size:12px;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px}
.cc-timeslot-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px;margin-bottom:4px}
.cc-slot-btn{padding:10px 8px;border:1.5px solid #ddd;border-radius:8px;background:#fafafa;font-size:13px;font-weight:500;color:#444;cursor:pointer;text-align:center;transition:all .2s;font-family:inherit}
.cc-slot-btn:hover{border-color:#632c76;color:#632c76;background:#f5f0fa}
.cc-slot-btn.selected{background:#632c76;color:#fff;border-color:#632c76;font-weight:700}
.cc-slot-btn.full{opacity:.45;cursor:not-allowed;text-decoration:line-through;background:#f5f5f5}
.cc-full-tag{display:block;font-size:10px;font-weight:700;color:#e53e3e;text-decoration:none;margin-top:2px}
.cc-proceed-btn{display:block;width:100%;padding:16px;background:#632c76;color:#fff;border:none;border-radius:35px 0 35px 35px;font-size:17px;font-weight:700;cursor:pointer;letter-spacing:1px;transition:background .3s;margin-top:8px}
.cc-proceed-btn:hover{background:#1253be}
.cc-field-err{font-size:12px;color:#c62828;display:block;margin-top:4px;font-weight:500}
.sd-toast{position:fixed;bottom:24px;right:24px;z-index:999999;background:#632c76;color:#fff;padding:14px 22px;border-radius:10px;font-size:15px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,.25);transform:translateY(100px);opacity:0;transition:all .35s ease;pointer-events:none;max-width:340px}
.sd-toast.show{transform:translateY(0);opacity:1}
.sd-toast.success{background:#2e7d32}
.sd-toast.error{background:#c62828}
@@media(max-width:600px){.cc-card{padding:20px 16px}.cc-toggle-row{flex-direction:column}.cc-grid-2{grid-template-columns:1fr}}
</style>
}

<div class="sd-toast" id="sdToast"></div>

<!-- ===== BANNER ===== -->
<div class="banner-outer">
  <div class="banner-box">
    <img src="@Url.Content("~/images/pathology-test-banner.png")" alt="Choose Collection – PATHLAB Diagnostics">
  </div>
</div>

<!-- ===== MAIN CONTENT ===== -->
<div class="inner-page-section why-section">
  <div class="wrapper clearfix">
    <div class="cc-wrap">
      <div class="cc-breadcrumb">
        <a href="@Url.Action("Index","Home")">Home</a> &gt; <a href="@Url.Action("BookTest","Test")">Book a Test</a> &gt; <a href="@Url.Action("Cart","Booking")">Cart</a> &gt; <span>Choose Collection</span>
      </div>

      <div class="cc-heading"><i class="fa fa-map-marker"></i> How will you give your sample?</div>
      <p class="cc-subheading">Choose your preferred collection method, then pick a date and time slot.</p>

      <!-- Type toggle -->
      <div class="cc-toggle-row">
        <div class="cc-type-card active" id="typeWalkin" onclick="setType('walkin')">
          <div class="cc-type-icon"><i class="fa fa-building"></i></div>
          <div>
            <div class="cc-type-title">&#127973; Walk-in at Branch</div>
            <div class="cc-type-desc">Visit any of our centres and give your sample there</div>
          </div>
        </div>
        <div class="cc-type-card" id="typeHome" onclick="setType('home')">
          <div class="cc-type-icon"><i class="fa fa-home"></i></div>
          <div>
            <div class="cc-type-title">&#127968; Home Collection</div>
            <div class="cc-type-desc">Our phlebotomist comes to your doorstep</div>
          </div>
        </div>
      </div>

      <!-- Walk-in panel -->
      <div class="cc-panel active" id="panelWalkin">
        <div class="cc-card">
          <h3><i class="fa fa-building"></i> Walk-in Details</h3>
          <div class="cc-form-row">
            <label>Select Branch</label>
            <select id="branchSel" onchange="refreshWalkinAvailability()">
              <option value="">— Choose a PATHLAB Diagnostics Centre —</option>
              <option value="BR001|Bhopal – Main Branch, MP Nagar">Bhopal – Main Branch, MP Nagar</option>
              <option value="BR002|Bhopal – Kolar Road Centre">Bhopal – Kolar Road Centre</option>
              <option value="BR003|Bhopal – Arera Colony">Bhopal – Arera Colony</option>
              <option value="BR004|Indore – Vijay Nagar">Indore – Vijay Nagar</option>
              <option value="BR005|Indore – Palasia Square">Indore – Palasia Square</option>
            </select>
          </div>
          <div class="cc-form-row">
            <label>Preferred Date</label>
            <input type="date" id="walkinDate" onchange="refreshWalkinAvailability()">
          </div>
          <div class="cc-form-row">
            <div class="cc-slots-label">Preferred Time Slot</div>
            <div class="cc-timeslot-grid" id="walkinSlots">
              <div style="grid-column:1/-1;color:#aaa;font-size:13px">Select a branch above to see its available slots.</div>
            </div>
          </div>
          <button class="cc-proceed-btn" onclick="proceedWalkin()">
            <i class="fa fa-arrow-right"></i>&nbsp; Continue to Order Review
          </button>
        </div>
      </div>

      <!-- Home collection panel -->
      <div class="cc-panel" id="panelHome">
        <div class="cc-card">
          <h3><i class="fa fa-home"></i> Home Collection Details</h3>
          <div class="cc-form-row">
            <label>Street / House No. / Area</label>
            <input type="text" id="addrStreet" placeholder="e.g. 42 MG Road, Shyam Nagar">
          </div>
          <div class="cc-grid-2">
            <div class="cc-form-row">
              <label>City</label>
              <input type="text" id="addrCity" placeholder="e.g. Bhopal">
            </div>
            <div class="cc-form-row">
              <label>State</label>
              <input type="text" id="addrState" placeholder="e.g. Madhya Pradesh">
            </div>
          </div>
          <div class="cc-grid-2">
            <div class="cc-form-row">
              <label>PIN Code</label>
              <input type="text" id="addrPin" placeholder="e.g. 462001" maxlength="6" oninput="this.value=this.value.replace(/\D/g,'')">
            </div>
            <div class="cc-form-row">
              <label>Address Type</label>
              <select id="addrType">
                <option value="Home">Home</option>
                <option value="Office">Office</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
          <div class="cc-form-row">
            <label>Preferred Collection Date</label>
            <input type="date" id="homeDate" onchange="refreshHomeAvailability()">
          </div>
          <div class="cc-form-row">
            <div class="cc-slots-label">Preferred Time Slot</div>
            <div class="cc-timeslot-grid" id="homeSlots">
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','07:00 – 08:00 AM',this)">07:00 – 08:00 AM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','08:00 – 09:00 AM',this)">08:00 – 09:00 AM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','09:00 – 10:00 AM',this)">09:00 – 10:00 AM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','10:00 – 11:00 AM',this)">10:00 – 11:00 AM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','11:00 AM – 12:00 PM',this)">11:00 AM – 12:00 PM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','12:00 – 01:00 PM',this)">12:00 – 01:00 PM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','02:00 – 03:00 PM',this)">02:00 – 03:00 PM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','03:00 – 04:00 PM',this)">03:00 – 04:00 PM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','04:00 – 05:00 PM',this)">04:00 – 05:00 PM</button>
              <button type="button" class="cc-slot-btn" onclick="selectSlot('home','05:00 – 06:00 PM',this)">05:00 – 06:00 PM</button>
            </div>
          </div>
          <button class="cc-proceed-btn" onclick="proceedHome()">
            <i class="fa fa-arrow-right"></i>&nbsp; Continue to Order Review
          </button>
        </div>
      </div>

    </div>
  </div>
</div>

@section scripts {
<script src="@Url.Content("~/Scripts/lims-api.js")"></script>
<script>
// All page-level state declared up front, before anything below can possibly
// run — a function called before its own module-scope `let`/`const` has
// executed throws a ReferenceError (temporal dead zone), which previously
// broke this page whenever the guard block below fired setType('home') or
// the branch/date fields already had a value on load.
let currentType='walkin';
let walkinSlot=null;
let homeSlot=null;

// Each branch has its own opening hours / slot capacity.
const ALL_SLOTS=['07:00 – 08:00 AM','08:00 – 09:00 AM','09:00 – 10:00 AM','10:00 – 11:00 AM','11:00 AM – 12:00 PM','12:00 – 01:00 PM','02:00 – 03:00 PM','03:00 – 04:00 PM','04:00 – 05:00 PM','05:00 – 06:00 PM'];
const BRANCH_SLOTS={
  'BR001': ALL_SLOTS, // Main branch — full day
  'BR002': ['07:00 – 08:00 AM','08:00 – 09:00 AM','09:00 – 10:00 AM','10:00 – 11:00 AM','11:00 AM – 12:00 PM','02:00 – 03:00 PM','03:00 – 04:00 PM'],
  'BR003': ['08:00 – 09:00 AM','09:00 – 10:00 AM','10:00 – 11:00 AM','11:00 AM – 12:00 PM','12:00 – 01:00 PM'],
  'BR004': ['07:00 – 08:00 AM','08:00 – 09:00 AM','09:00 – 10:00 AM','04:00 – 05:00 PM','05:00 – 06:00 PM'],
  'BR005': ['09:00 – 10:00 AM','10:00 – 11:00 AM','11:00 AM – 12:00 PM','12:00 – 01:00 PM','02:00 – 03:00 PM','03:00 – 04:00 PM','04:00 – 05:00 PM']
};

// Guards
(function(){
  const cart=JSON.parse(sessionStorage.getItem('sd_cart')||'[]');
  const user=JSON.parse(localStorage.getItem('sd_user')||'null');
  if(!cart.length) { window.location.href='@Url.Action("BookTest","Test")'; return; }
  if(!user) { window.location.href='@Url.Action("Login","Account")?next=@Url.Action("ChooseCollection","Booking")'; return; }
  const today=new Date().toISOString().split('T')[0];
  document.getElementById('walkinDate').min=today;
  document.getElementById('homeDate').min=today;

  // Home Collection lead popup on the homepage hands off here: pre-select Home
  // Collection and pre-fill the city they already typed, so nothing they
  // entered there gets thrown away once they reach the actual booking flow.
  const homeLead=JSON.parse(sessionStorage.getItem('sd_home_lead')||'null');
  if(homeLead){
    setType('home');
    if(homeLead.city) document.getElementById('addrCity').value=homeLead.city;
    sessionStorage.removeItem('sd_home_lead');
  }
})();

// Slots already at capacity for the chosen date (from WCF GetBookedSlots, or
// local bookings when offline) — rendered greyed-out so no one double-books.
let walkinFull=[];
let homeFull=[];

function slotBtnHtml(type,s,full,selected){
  return '<button type="button" class="cc-slot-btn'+(full?' full':'')+(selected?' selected':'')+'"'+
         (full?' disabled':'')+' onclick="selectSlot(\''+type+'\',\''+s+'\',this)">'+s+
         (full?'<span class="cc-full-tag">Full</span>':'')+'</button>';
}

function renderWalkinSlots(){
  const grid=document.getElementById('walkinSlots');
  const raw=document.getElementById('branchSel').value;
  if(!raw){ walkinSlot=null; grid.innerHTML='<div style="grid-column:1/-1;color:#aaa;font-size:13px">Select a branch above to see its available slots.</div>'; return; }
  const branchID=raw.split('|')[0];
  const slots=BRANCH_SLOTS[branchID]||ALL_SLOTS;
  if(walkinFull.indexOf(walkinSlot)!==-1 || slots.indexOf(walkinSlot)===-1) walkinSlot=null;
  grid.innerHTML=slots.map(function(s){
    return slotBtnHtml('walkin',s,walkinFull.indexOf(s)!==-1,s===walkinSlot);
  }).join('');
}

function renderHomeSlots(){
  const grid=document.getElementById('homeSlots');
  if(homeFull.indexOf(homeSlot)!==-1) homeSlot=null;
  grid.innerHTML=ALL_SLOTS.map(function(s){
    return slotBtnHtml('home',s,homeFull.indexOf(s)!==-1,s===homeSlot);
  }).join('');
}

function refreshWalkinAvailability(){
  const raw=document.getElementById('branchSel').value;
  const date=document.getElementById('walkinDate').value;
  walkinFull=[];
  renderWalkinSlots();
  if(!raw||!date) return;
  LIMS.getBookedSlots(date,'walkin',raw.split('|')[1]).then(function(full){
    walkinFull=full||[];
    renderWalkinSlots();
  });
}

function refreshHomeAvailability(){
  const date=document.getElementById('homeDate').value;
  homeFull=[];
  renderHomeSlots();
  if(!date) return;
  LIMS.getBookedSlots(date,'home','').then(function(full){
    homeFull=full||[];
    renderHomeSlots();
  });
}

function showToast(msg,type){
  const t=document.getElementById('sdToast');
  t.textContent=msg; t.className='sd-toast '+(type||'');
  setTimeout(()=>t.classList.add('show'),10);
  setTimeout(()=>t.classList.remove('show'),3200);
}

function setType(type){
  currentType=type;
  document.getElementById('typeWalkin').classList.toggle('active',type==='walkin');
  document.getElementById('typeHome').classList.toggle('active',type==='home');
  document.getElementById('panelWalkin').classList.toggle('active',type==='walkin');
  document.getElementById('panelHome').classList.toggle('active',type==='home');
}

function selectSlot(type,slot,btn){
  const grid=document.getElementById(type==='walkin'?'walkinSlots':'homeSlots');
  grid.querySelectorAll('.cc-slot-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  if(type==='walkin') walkinSlot=slot;
  else homeSlot=slot;
}

function proceedWalkin(){
  const branchRaw=document.getElementById('branchSel').value;
  const date=document.getElementById('walkinDate').value;
  if(!branchRaw){ showToast('Please select a branch.','error'); return; }
  if(!date){ showToast('Please select a preferred date.','error'); return; }
  if(!walkinSlot){ showToast('Please select a time slot.','error'); return; }
  if(walkinFull.indexOf(walkinSlot)!==-1){ showToast('That slot just filled up. Please pick another.','error'); refreshWalkinAvailability(); return; }
  const [branchID,branchName]=branchRaw.split('|');
  const col={type:'walkin', branchID, branchName, date, timeSlot:walkinSlot};
  sessionStorage.setItem('sd_collection',JSON.stringify(col));
  window.location.href='@Url.Action("Checkout","Booking")';
}

function proceedHome(){
  const street=document.getElementById('addrStreet').value.trim();
  const city=document.getElementById('addrCity').value.trim();
  const pin=document.getElementById('addrPin').value.trim();
  const state=document.getElementById('addrState').value.trim();
  const addrType=document.getElementById('addrType').value;
  const date=document.getElementById('homeDate').value;
  if(!street){ showToast('Please enter your street/area.','error'); return; }
  if(!city){ showToast('Please enter your city.','error'); return; }
  if(!pin||pin.length<6){ showToast('Please enter a valid 6-digit PIN code.','error'); return; }
  if(!date){ showToast('Please select a preferred date.','error'); return; }
  if(!homeSlot){ showToast('Please select a time slot.','error'); return; }
  if(homeFull.indexOf(homeSlot)!==-1){ showToast('That slot just filled up. Please pick another.','error'); refreshHomeAvailability(); return; }
  const col={type:'home', address:{street,city,state,pin,type:addrType}, date, timeSlot:homeSlot};
  sessionStorage.setItem('sd_collection',JSON.stringify(col));
  window.location.href='@Url.Action("Checkout","Booking")';
}

// Browser back/forward-cache restores can put a value back into the branch/date
// fields without firing their "change" event, leaving the slot grid stuck on
// "Select a branch above..." even though a branch is already selected. Re-sync
// once now that every variable/function above is initialized (and again on any
// bfcache restore) so the grid always matches whatever the fields actually show.
refreshWalkinAvailability();
refreshHomeAvailability();
window.addEventListener('pageshow', function (e) {
  if (e.persisted) { refreshWalkinAvailability(); refreshHomeAvailability(); }
});
</script>
}

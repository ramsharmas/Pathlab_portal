    </div> 
</div>
 
<!--=============== BODY SECTION ======================-->
<div class="inner-page-section">
	<div class="wrapper clearfix">
    	<div class="path-box">
        	<p><a href="@Url.Action("Index","Home")">Home</a> &gt; <span>Pathlab Plus</span></p>
        </div>
    	<h2 class="big-text">A Step Towards a Healthy Tomorrow</h2>

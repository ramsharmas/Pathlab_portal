                	<h3>No Investment</h3> </span>
                </div> 
            </div> 
        	<div class="staff-box-three">
            	<div class="staff-pic-two">
                	<span><img src="@Url.Content("~/images/lp-2.png")">
                	<h3>No Additional Infrastructure</h3> </span>
                </div> 
            </div> 
        	<div class="staff-box-three">
            	<div class="staff-pic-two">
                	<span><img src="@Url.Content("~/images/lp-3.png")">
                	<h3>Increased Client Acquisitions</h3></span>
                </div> 
            </div> 
        	<div class="staff-box-three">
            	<div class="staff-pic-two">
                	<span><img src="@Url.Content("~/images/lp-4.png")">
                	<h3>Daily Customer Sign-Up Tracker</h3></span>
                </div> 
            </div> 
        	<div class="staff-box-three">
            	<div class="staff-pic-two">
                	<span><img src="@Url.Content("~/images/lp-5.png")">
                	<h3>Training Materials for Pharmacists</h3> </span>
                </div> 
            </div> 
        	<div class="staff-box-three">
            	<div class="staff-pic-two">
                	<span><img src="@Url.Content("~/images/lp-6.png")">
                	<h3>Pharmacy Kit</h3></span>
                </div> 
            </div> 
        	<div class="staff-box-three">
            	<div class="staff-pic-two">
                	<span><img src="@Url.Content("~/images/lp-7.png")">
                	<h3>Maintenance of Prescription</h3></span>
                </div> 
            </div>  
        </div> 
        </div>
    </div>
</div>
 

<div class="consumer-section">
	<div class="wrapper">
    	<div class="title-box">
            <h2>#ScanKaro Benefits For the Consumers</h2>
            <p>Applicable only associated pharmacies of Swapnil Diagnostics</p>
        </div>
    	<div class="consumer-box-outer">
        	<h3>Scan to Get</h3>
            <div class="consumer-fild">
            	<ul class="clearfix">
                    <li><span>Free Home Collection</span> <img src="@Url.Content("~/images/c-3.png")"></li>
                    <li><span>NABL Accredited strong quality <br>control driven lab processes</span> <img src="@Url.Content("~/images/c-2.png")"></li>
                    <li><span>Smart Reports</span> <img src="@Url.Content("~/images/c-5.png")"></li>
                    <li><span>ISO Certified Home Collection <br>and Logistics Services</span> <img src="@Url.Content("~/images/c-4.png")"></li>
                    <li><span>Guaranteed Booking Slots</span> <img src="@Url.Content("~/images/c-6.png")"></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="inner-page-section why-section">
	<div class="wrapper">
    	<div class="get-touch-outer">
        	<h2>Get In Touch</h2> 
             <div class="get-touch-fild clearfix">
            	<div class="half-length">
                	<div class="fild-box"> 
                        <input type="text" placeholder="Enter your first name and last name">
                    </div>
                </div>
            	<div class="half-length">
                	<div class="fild-box"> 
                        <input type="text" placeholder="Enter your 10 Digit mobile number">
                    </div>
                </div>
            	<div class="full-length">
                	<div class="fild-box"> 
                        <select>
                        	<option>Kolkata</option>
                        	<option>Delhi</option>
                        	<option>Mumbai</option>
                        	<option>Chennai</option> 
                        </select>
                    </div>
                </div> 
            	<div class="full-length">
                	<div class="fild-box">
                    	<button class="btn">Submit</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


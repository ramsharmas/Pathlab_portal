@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool adminAuthed = ViewBag.AdminAuthed == true;
}

@section styles {
<style>
.adm-layout{display:flex;min-height:calc(100vh - 120px)}
.adm-sidebar{width:220px;background:#2d0a3e;flex-shrink:0;padding:0}
.adm-sidebar-brand{padding:20px 18px;border-bottom:1px solid rgba(255,255,255,.1);color:#fff}
.adm-sidebar-brand h4{margin:0;font-size:15px;font-weight:700}
.adm-sidebar-brand p{margin:0;font-size:12px;opacity:.6}
.adm-nav-item{display:flex;align-items:center;gap:12px;padding:13px 18px;color:rgba(255,255,255,.7);font-size:14px;cursor:pointer;border-left:3px solid transparent;transition:all .2s}
.adm-nav-item:hover{background:rgba(255,255,255,.08);color:#fff}
.adm-nav-item.active{background:rgba(255,255,255,.12);color:#fff;border-left-color:#dba5f0}
.adm-nav-item i{width:18px;text-align:center}
.adm-content{flex:1;background:#f8f5fc;padding:28px}
.adm-topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
.adm-topbar h2{font-size:22px;font-weight:700;color:#2d0a3e;margin:0}
.adm-stats{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:28px}
.stat-card{background:#fff;border-radius:16px;padding:22px;box-shadow:0 2px 12px rgba(99,44,118,.07)}
.stat-card .stat-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:14px}
.stat-card .stat-num{font-size:28px;font-weight:800;color:#2d0a3e}
.stat-card .stat-label{font-size:13px;color:#888;margin-top:4px}
.adm-card{background:#fff;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(99,44,118,.07);margin-bottom:24px}
.adm-card h3{font-size:17px;font-weight:700;color:#2d0a3e;margin-bottom:18px}
.adm-table{width:100%;border-collapse:collapse}
.adm-table th{background:#2d0a3e;color:#fff;padding:12px 16px;text-align:left;font-size:13px;font-weight:600}
.adm-table td{padding:11px 16px;border-bottom:1px solid #f5f0fa;font-size:13px}
.adm-table tr:last-child td{border-bottom:none}
.adm-table tr:hover td{background:#faf5ff}
.sd-badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:12px;font-size:12px;font-weight:700}
.status-booked{background:#e3f2fd;color:#1565c0}
.status-confirmed{background:#e8f5e9;color:#2e7d32}
.status-ready{background:#e0f7fa;color:#00695c}
.status-processing{background:#f3e5f5;color:#7b1fa2}
.adm-search{display:flex;gap:10px;margin-bottom:18px}
.adm-search input{flex:1;padding:10px 14px;border:1px solid #ddd;border-radius:8px;font-size:14px;font-family:inherit}
.adm-search input:focus{border-color:#632c76;outline:none}
.adm-date-filter{display:flex;gap:10px;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap}
.adm-date-filter label{display:block;font-size:12px;color:#888;margin-bottom:4px}
.adm-date-filter input{padding:9px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px}
.adm-trend{display:flex;align-items:flex-end;gap:6px;height:160px;padding:8px 4px 0}
.adm-trend-bar{flex:1;min-width:6px;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%}
.adm-trend-bar .bar{width:100%;max-width:28px;background:#632c76;border-radius:4px 4px 0 0;min-height:2px;transition:background .15s}
.adm-trend-bar:hover .bar{background:#1253be}
.adm-trend-bar .tip{position:absolute;bottom:100%;margin-bottom:6px;background:#2d0a3e;color:#fff;font-size:11px;padding:6px 9px;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s;z-index:5}
.adm-trend-bar:hover .tip{opacity:1}
.adm-trend-axis{display:flex;justify-content:space-between;font-size:11px;color:#999;margin-top:6px}
/* ── PIN Gate ── */
.adm-gate{position:fixed;inset:0;background:rgba(13,4,22,.92);z-index:9999;display:flex;align-items:center;justify-content:center;}
.adm-gate-card{background:#fff;border-radius:20px;padding:44px 40px;width:100%;max-width:380px;box-shadow:0 24px 60px rgba(0,0,0,.5);text-align:center;}
.adm-gate-card .gate-icon{width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,#2d0a3e,#632c76);display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px;}
.adm-gate-card h2{font-size:22px;font-weight:800;color:#2d0a3e;margin:0 0 4px;}
.adm-gate-card p{font-size:14px;color:#888;margin:0 0 24px;}
.adm-gate-card input[type=password]{width:100%;padding:13px 16px;border:1.5px solid #ddd;border-radius:10px;font-size:22px;letter-spacing:8px;text-align:center;margin-bottom:16px;outline:none;transition:border-color .15s;box-sizing:border-box;}
.adm-gate-card input[type=password]:focus{border-color:#632c76;}
.adm-gate-card .gate-btn{width:100%;padding:13px;background:linear-gradient(135deg,#2d0a3e,#632c76);color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;transition:opacity .15s;}
.adm-gate-card .gate-btn:hover{opacity:.88;}
.adm-gate-card .gate-err{background:#fdecea;color:#c62828;border-radius:8px;padding:9px 14px;font-size:13px;margin-bottom:14px;}
</style>
}

@if (!adminAuthed)
{
    <!-- ── Admin PIN Gate ───────────────────────────────────────────── -->
    <div class="adm-gate" id="adm-gate">
        <div class="adm-gate-card">
            <div class="gate-icon"><i class="fa fa-lock" style="font-size:28px;color:#fff"></i></div>
            <h2>Admin Access</h2>
            <p>Enter your admin PIN to continue</p>
            @if (TempData["LoginError"] != null)
            {
                <div class="gate-err"><i class="fa fa-exclamation-circle"></i> @TempData["LoginError"]</div>
            }
            @using (Html.BeginForm("Login", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="password" name="pin" id="adminPinInput" placeholder="••••"
                       autocomplete="current-password" maxlength="20"
                       autofocus style="ime-mode:disabled" />
                <button type="submit" class="gate-btn"><i class="fa fa-sign-in"></i> Enter Dashboard</button>
            }
        </div>
    </div>
}
else
{
<div data-ng-controller="AdminController">
<div class="adm-layout">

    <!-- Sidebar -->
    <div class="adm-sidebar">
        <div class="adm-sidebar-brand">
            <h4>Admin Panel</h4>
            <p>PATHLAB Diagnostics</p>
            @using (Html.BeginForm("Logout", "Admin", FormMethod.Post, new { style = "margin-top:10px" }))
            {
                @Html.AntiForgeryToken()
                <button type="submit" style="background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.2);border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;width:100%">
                    <i class="fa fa-sign-out"></i> Logout
                </button>
            }
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='overview'}" data-ng-click="setTab('overview')">
            <i class="fa fa-tachometer"></i> Overview
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='bookings'}" data-ng-click="setTab('bookings')">
            <i class="fa fa-calendar-check-o"></i> Bookings
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='patients'}" data-ng-click="setTab('patients')">
            <i class="fa fa-users"></i> Patients
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='reconciliation'}" data-ng-click="setTab('reconciliation')">
            <i class="fa fa-balance-scale"></i> Reconciliation
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='feedback'}" data-ng-click="setTab('feedback')">
            <i class="fa fa-comments"></i> Feedback
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='leads'}" data-ng-click="setTab('leads')">
            <i class="fa fa-phone"></i> Home Collection Leads
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='notifications'}" data-ng-click="setTab('notifications')">
            <i class="fa fa-paper-plane"></i> Notifications Log
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='audit'}" data-ng-click="setTab('audit')">
            <i class="fa fa-shield"></i> Audit Trail
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='lims'}" data-ng-click="setTab('lims')">
            <i class="fa fa-exchange"></i> LIMS Sync
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='queue'}" data-ng-click="setTab('queue')">
            <i class="fa fa-motorcycle"></i> Collection Queue
        </div>
        <div class="adm-nav-item" data-ng-class="{active: activeTab=='analytics'}" data-ng-click="setTab('analytics')">
            <i class="fa fa-bar-chart"></i> Analytics
        </div>
    </div>

    <!-- Main Content -->
    <div class="adm-content">

        <!-- Overview -->
        <div data-ng-show="activeTab=='overview'">
            <div class="adm-topbar">
                <h2><i class="fa fa-tachometer"></i> Dashboard Overview</h2>
                <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="loadStats()">
                    <i class="fa fa-refresh"></i> Refresh
                </button>
            </div>

            <div class="adm-stats" data-ng-show="stats">
                <div class="stat-card">
                    <div class="stat-icon" style="background:#f3e5f5"><i class="fa fa-users" style="color:#7b1fa2"></i></div>
                    <div class="stat-num">{{stats.TotalPatients}}</div>
                    <div class="stat-label">Total Patients</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background:#e3f2fd"><i class="fa fa-calendar" style="color:#1565c0"></i></div>
                    <div class="stat-num">{{stats.TotalBookings}}</div>
                    <div class="stat-label">Total Bookings</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background:#e0f7fa"><i class="fa fa-file-text-o" style="color:#00695c"></i></div>
                    <div class="stat-num">{{stats.TotalReports}}</div>
                    <div class="stat-label">Reports Ready</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background:#e8f5e9"><i class="fa fa-flask" style="color:#2e7d32"></i></div>
                    <div class="stat-num">{{stats.TotalTests}}</div>
                    <div class="stat-label">Lab Tests</div>
                </div>
            </div>

            <div class="adm-card" data-ng-show="staffAlerts.length>0">
                <h3><i class="fa fa-bell" style="color:#e67e22"></i> Staff Alerts <span style="background:#e53e3e;color:#fff;border-radius:10px;padding:1px 9px;font-size:12px;margin-left:6px">{{staffAlerts.length}}</span></h3>
                <div data-ng-repeat="a in staffAlerts" style="display:flex;gap:12px;align-items:flex-start;padding:12px 0;border-bottom:1px solid #f5f0fa">
                    <i class="fa" data-ng-class="a.Icon" style="width:20px;text-align:center;margin-top:2px" data-ng-style="{color: a.Level=='danger' ? '#c62828' : '#e67e22'}"></i>
                    <div>
                        <div style="font-size:14px;font-weight:700;color:#222">{{a.Title}}</div>
                        <div style="font-size:13px;color:#666;margin-top:2px">{{a.Detail}}</div>
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <h3>Top Tests</h3>
                <table class="adm-table">
                    <thead><tr><th>Test</th><th>Times Booked</th><th>Revenue</th></tr></thead>
                    <tbody>
                        <tr data-ng-repeat="t in topTests">
                            <td><strong style="color:#632c76">{{t.name}}</strong></td>
                            <td>{{t.count}}</td>
                            <td>&#8377;{{t.revenue}}</td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="topTests.length==0" style="text-align:center;padding:20px;color:#aaa">No bookings yet</div>
            </div>

            <div class="adm-card">
                <h3>Recent Bookings</h3>
                <table class="adm-table">
                    <thead>
                        <tr><th>Booking Ref</th><th>Patient</th><th>Tests</th><th>Amount</th><th>Status</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="b in recentBookings | limitTo:8">
                            <td><strong style="color:#632c76">{{b.BookingRef}}</strong></td>
                            <td>{{b.PatientName}}</td>
                            <td>{{b.Tests.length}} test(s)</td>
                            <td>&#8377;{{b.TotalAmount}}</td>
                            <td><span class="sd-badge status-{{b.BookingStatus.toLowerCase()}}">{{b.BookingStatus}}</span></td>
                            <td>{{b.CreatedAt | date:'dd MMM yyyy'}}</td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="recentBookings.length==0" style="text-align:center;padding:30px;color:#aaa">No bookings yet</div>
            </div>
        </div>

        <!-- Bookings -->
        <div data-ng-show="activeTab=='bookings'">
            <div class="adm-topbar">
                <h2><i class="fa fa-calendar-check-o"></i> All Bookings</h2>
            </div>
            <div class="adm-card">
                <div class="adm-search">
                    <input type="text" placeholder="Search by booking ref or patient name..." data-ng-model="bookingFilter">
                </div>
                <table class="adm-table">
                    <thead>
                        <tr><th>Booking Ref</th><th>Patient</th><th>Phone</th><th>Tests</th><th>Amount</th><th>Payment</th><th>Collection</th><th>Status</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="b in allBookings | filter:bookingFilter">
                            <td><strong style="color:#632c76">{{b.BookingRef}}</strong></td>
                            <td>{{b.PatientName}}</td>
                            <td>{{b.PatientPhone}}</td>
                            <td>{{b.Tests.length}}</td>
                            <td>&#8377;{{b.TotalAmount}}</td>
                            <td style="white-space:nowrap">
                                <div data-ng-show="b.PaymentStatus=='Paid'" style="color:#2e7d32;font-weight:600" title="{{b.PaymentRef ? 'Txn ' + b.PaymentRef : ''}}"><i class="fa fa-check-circle"></i> Paid</div>
                                <div data-ng-show="b.PaymentStatus=='Refunded'" style="color:#c62828;font-weight:600">
                                    <i class="fa fa-undo"></i> Refunded &#8377;{{b.RefundAmount}}
                                </div>
                                <div data-ng-show="b.PaymentStatus=='PartiallyPaid'" style="color:#e65100;font-weight:600;margin-bottom:4px">
                                    &#8377;{{b.AmountPaid}} / {{b.TotalAmount}} paid
                                </div>
                                <div data-ng-show="(b.PaymentStatus=='Pending' || b.PaymentStatus=='PartiallyPaid') && b.BookingStatus!='Cancelled'" style="display:flex;gap:4px;margin-bottom:4px">
                                    <button data-ng-click="markPaid(b)"
                                            style="border:1px solid #632c76;color:#632c76;background:#fff;border-radius:6px;padding:3px 8px;font-size:12px;cursor:pointer"
                                            title="Record full counter payment received">
                                        <i class="fa fa-inr"></i> Mark Paid
                                    </button>
                                    <input type="number" data-ng-model="b._partialAmount" placeholder="Amt" style="width:60px;border:1px solid #ddd;border-radius:6px;padding:3px 6px;font-size:12px">
                                    <button data-ng-click="recordPartialPayment(b)"
                                            style="border:1px solid #888;color:#555;background:#fff;border-radius:6px;padding:3px 8px;font-size:12px;cursor:pointer"
                                            title="Record a partial payment installment">Part</button>
                                </div>
                                <button data-ng-show="(b.PaymentStatus=='Paid' || b.PaymentStatus=='PartiallyPaid')" data-ng-click="refundBooking(b)"
                                        style="border:1px solid #c62828;color:#c62828;background:#fff;border-radius:6px;padding:3px 8px;font-size:12px;cursor:pointer">
                                    <i class="fa fa-undo"></i> Refund
                                </button>
                            </td>
                            <td>
                                <span data-ng-show="b.CollectionType=='home'"><i class="fa fa-home"></i> Home</span>
                                <span data-ng-show="b.CollectionType=='walkin'"><i class="fa fa-building-o"></i> Walk-in</span>
                            </td>
                            <td>
                                <select data-ng-model="b.BookingStatus" data-ng-change="updateStatus(b)"
                                        style="border:1px solid #ddd;border-radius:6px;padding:4px 8px;font-size:13px;cursor:pointer">
                                    <option value="Booked">Booked</option>
                                    <option value="Confirmed">Confirmed</option>
                                    <option value="Processing">Processing</option>
                                    <option value="Ready">Ready</option>
                                </select>
                            </td>
                            <td>{{b.CreatedAt | date:'dd MMM yy'}}</td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="isLoadingBookings" style="text-align:center;padding:30px;color:#632c76">
                    <i class="fa fa-spinner fa-spin fa-2x"></i>
                </div>
            </div>
        </div>

        <!-- RECONCILIATION (Billing Phase 4) -->
        <div data-ng-show="activeTab=='reconciliation'">
            <div class="adm-topbar">
                <h2><i class="fa fa-balance-scale"></i> Payment Reconciliation</h2>
                <button style="background:#fff;color:#632c76;border:1px solid #632c76;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="exportReconciliationCsv()">
                    <i class="fa fa-download"></i> Export CSV
                </button>
            </div>
            <div class="adm-card">
                <div class="adm-date-filter">
                    <div><label>From</label><input type="date" data-ng-model="reconFrom"></div>
                    <div><label>To</label><input type="date" data-ng-model="reconTo"></div>
                    <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="applyReconFilter()">Apply</button>
                    <span style="font-size:12px;color:#999">Defaults to the last 30 days when left blank.</span>
                </div>
                <div class="adm-stats" style="margin-bottom:0" data-ng-show="reconciliation">
                    <div class="stat-card"><div class="stat-num">&#8377;{{reconciliation.TotalBilled}}</div><div class="stat-label">Total billed</div></div>
                    <div class="stat-card"><div class="stat-num" style="color:#2e7d32">&#8377;{{reconciliation.TotalCollected}}</div><div class="stat-label">Total collected</div></div>
                    <div class="stat-card"><div class="stat-num" style="color:#c62828">&#8377;{{reconciliation.TotalRefunded}}</div><div class="stat-label">Total refunded</div></div>
                    <div class="stat-card"><div class="stat-num" style="color:#e65100">&#8377;{{reconciliation.TotalOutstanding}}</div><div class="stat-label">Outstanding</div></div>
                </div>
            </div>
            <div class="adm-card">
                <table class="adm-table">
                    <thead>
                        <tr><th>Booking Ref</th><th>Date</th><th>Patient</th><th>Total</th><th>Paid</th><th>Status</th><th>Gateway Txn</th><th>Refund</th><th>Invoice</th><th>LIMS</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="r in reconciliation.Rows">
                            <td><strong style="color:#632c76">{{r.BookingRef}}</strong></td>
                            <td>{{r.CreatedAt | date:'dd MMM yy'}}</td>
                            <td>{{r.PatientName}}</td>
                            <td>&#8377;{{r.TotalAmount}}</td>
                            <td>&#8377;{{r.AmountPaid}}</td>
                            <td>{{r.PaymentStatus}}</td>
                            <td style="font-size:12px;color:#888">{{r.PaymentRef || '-'}}</td>
                            <td data-ng-show="r.RefundAmount">&#8377;{{r.RefundAmount}}</td>
                            <td data-ng-hide="r.RefundAmount">-</td>
                            <td style="font-size:12px">{{r.InvoiceNumber || '-'}}</td>
                            <td style="font-size:12px">{{r.LimsSyncStatus || '-'}}</td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="reconciliation && reconciliation.Rows.length==0" style="text-align:center;padding:30px;color:#aaa">No bookings in this range</div>
            </div>
        </div>

        <!-- FEEDBACK / COMPLAINTS (Help section fix) -->
        <div data-ng-show="activeTab=='feedback'">
            <div class="adm-topbar">
                <h2><i class="fa fa-comments"></i> Patient Feedback &amp; Complaints</h2>
                <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="setTab('feedback')">
                    <i class="fa fa-refresh"></i> Refresh
                </button>
            </div>
            <div class="adm-card">
                <table class="adm-table">
                    <thead>
                        <tr><th>When</th><th>Name</th><th>Phone</th><th>Booking Ref</th><th>Message</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="f in allFeedback">
                            <td style="white-space:nowrap">{{f.CreatedAt | date:'dd MMM, HH:mm'}}</td>
                            <td>{{f.Name || 'Guest'}}</td>
                            <td>{{f.Phone || '-'}}</td>
                            <td>{{f.BookingRef || '-'}}</td>
                            <td style="max-width:320px;word-break:break-word">{{f.Message}}</td>
                            <td><span class="sd-badge" data-ng-class="f.Status=='Resolved' ? 'status-ready' : 'status-pending'">{{f.Status}}</span></td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="isLoadingFeedback" style="text-align:center;padding:30px;color:#632c76"><i class="fa fa-spinner fa-spin fa-2x"></i></div>
                <div data-ng-show="!isLoadingFeedback && allFeedback.length==0" style="text-align:center;padding:30px;color:#aaa">No feedback submitted yet</div>
            </div>
        </div>

        <!-- HOME COLLECTION LEADS (Home Collection popup fix) -->
        <div data-ng-show="activeTab=='leads'">
            <div class="adm-topbar">
                <h2><i class="fa fa-phone"></i> Home Collection Leads</h2>
                <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="setTab('leads')">
                    <i class="fa fa-refresh"></i> Refresh
                </button>
            </div>
            <div class="adm-card">
                <p style="font-size:13px;color:#888;margin-top:-6px;margin-bottom:16px">Submitted from the "Book Home Collection" popup on the homepage — call these back to schedule a visit.</p>
                <table class="adm-table">
                    <thead>
                        <tr><th>When</th><th>Name</th><th>Mobile</th><th>City</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="l in allLeads">
                            <td style="white-space:nowrap">{{l.CreatedAt | date:'dd MMM, HH:mm'}}</td>
                            <td>{{l.Name}}</td>
                            <td>{{l.Mobile}}</td>
                            <td>{{l.City || '-'}}</td>
                            <td><span class="sd-badge" data-ng-class="l.Status=='New' ? 'status-booked' : 'status-ready'">{{l.Status}}</span></td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="isLoadingLeads" style="text-align:center;padding:30px;color:#632c76"><i class="fa fa-spinner fa-spin fa-2x"></i></div>
                <div data-ng-show="!isLoadingLeads && allLeads.length==0" style="text-align:center;padding:30px;color:#aaa">No home collection leads yet</div>
            </div>
        </div>

        <!-- Patients -->
        <div data-ng-show="activeTab=='patients'">
            <div class="adm-topbar">
                <h2><i class="fa fa-users"></i> Registered Patients</h2>
            </div>
            <div class="adm-card">
                <div class="adm-search">
                    <input type="text" placeholder="Search by name or phone..." data-ng-model="patientFilter">
                </div>
                <table class="adm-table">
                    <thead>
                        <tr><th>ID</th><th>Name</th><th>Phone</th><th>Email</th><th>Gender</th><th>City</th><th>Registered</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="p in allPatients | filter:patientFilter">
                            <td>{{p.PatientId}}</td>
                            <td><strong>{{p.FullName}}</strong></td>
                            <td>{{p.Phone}}</td>
                            <td>{{p.Email}}</td>
                            <td>{{p.Gender}}</td>
                            <td>{{p.City}}</td>
                            <td>{{p.CreatedDate | date:'dd MMM yyyy'}}</td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="isLoadingPatients" style="text-align:center;padding:30px;color:#632c76">
                    <i class="fa fa-spinner fa-spin fa-2x"></i>
                </div>
            </div>
        </div>

        <!-- Notifications Log -->
        <div data-ng-show="activeTab=='notifications'">
            <div class="adm-topbar">
                <h2><i class="fa fa-paper-plane"></i> Notification Log</h2>
                <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="setTab('notifications')">
                    <i class="fa fa-refresh"></i> Refresh
                </button>
            </div>
            <div class="adm-card">
                <table class="adm-table">
                    <thead>
                        <tr><th>Sent</th><th>Type</th><th>Booking Ref</th><th>Phone</th><th>Message</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="n in notificationLogs">
                            <td style="white-space:nowrap">{{n.CreatedAt | date:'dd MMM, HH:mm'}}</td>
                            <td>{{n.Type}}</td>
                            <td><strong style="color:#632c76">{{n.BookingRef}}</strong></td>
                            <td>{{n.Phone}}</td>
                            <td style="max-width:320px;word-break:break-word;font-size:12px">{{n.Message}}</td>
                            <td>
                                <span class="sd-badge" data-ng-show="n.Success" style="background:#e8f5e9;color:#2e7d32">Sent</span>
                                <span class="sd-badge" data-ng-hide="n.Success" style="background:#fdecea;color:#c62828" title="{{n.ErrorDetail}}">Skipped/Failed</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="notificationLogs.length==0" style="text-align:center;padding:30px;color:#aaa">No notifications sent yet</div>
            </div>
        </div>

        <!-- Audit Trail -->
        <div data-ng-show="activeTab=='audit'">
            <div class="adm-topbar">
                <h2><i class="fa fa-shield"></i> Audit Trail</h2>
                <div style="display:flex;gap:8px">
                    <button style="background:#fff;color:#632c76;border:1px solid #632c76;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="exportAuditCsv()">
                        <i class="fa fa-download"></i> Export CSV
                    </button>
                    <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="setTab('audit')">
                        <i class="fa fa-refresh"></i> Refresh
                    </button>
                </div>
            </div>

            <div class="adm-card" data-ng-show="auditChain">
                <div style="display:flex;align-items:center;gap:14px" data-ng-show="auditChain.Intact">
                    <i class="fa fa-check-circle" style="font-size:28px;color:#2e7d32"></i>
                    <div>
                        <div style="font-weight:700;color:#2e7d32">Chain intact — no tampering detected</div>
                        <div style="font-size:12px;color:#888">{{auditChain.TotalRows}} audit entries verified, hash-linked end to end.</div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:14px" data-ng-hide="auditChain.Intact">
                    <i class="fa fa-exclamation-triangle" style="font-size:28px;color:#c62828"></i>
                    <div>
                        <div style="font-weight:700;color:#c62828">Tampering detected at AuditLogId {{auditChain.BrokenAtId}}</div>
                        <div style="font-size:12px;color:#888">Hash chain breaks here — row content, order, or presence no longer matches what was originally logged.</div>
                    </div>
                </div>
            </div>

            <!-- Compliance report (Phase 4) — supporting documentation for an
                 NABH/NABL accreditation audit, NOT a certified audit itself. -->
            <div class="adm-card" data-ng-show="compliance">
                <h3><i class="fa fa-clipboard"></i> Compliance Report <span style="font-size:11px;font-weight:400;color:#999">(supporting documentation — not a certified audit)</span></h3>
                <div class="adm-stats" style="margin-bottom:0">
                    <div class="stat-card">
                        <div class="stat-num" data-ng-style="{color: compliance.AuditChainIntact ? '#2e7d32' : '#c62828'}">{{compliance.AuditChainIntact ? 'Intact' : 'Broken'}}</div>
                        <div class="stat-label">Audit chain status ({{compliance.TotalAuditEntries}} entries)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#2e7d32">{{compliance.BookingsWithFullCustodyTrail}}</div>
                        <div class="stat-label">Bookings with full custody trail</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#e65100">{{compliance.BookingsMissingCustodyTrail}}</div>
                        <div class="stat-label">Bookings missing custody trail</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num">{{compliance.TotalCustodyEvents}}</div>
                        <div class="stat-label">Total custody events logged</div>
                    </div>
                </div>
                <div style="margin-top:16px;font-size:13px;color:#666;line-height:1.6">
                    <strong>Data retention:</strong> {{compliance.DataRetentionNote}}<br>
                    <strong>Access control:</strong> {{compliance.AccessControlNote}}
                </div>
            </div>

            <div class="adm-card">
                <table class="adm-table">
                    <thead>
                        <tr><th>When</th><th>Actor</th><th>Action</th><th>Entity</th><th>Detail</th><th>IP</th><th>Result</th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="a in auditLogs">
                            <td style="white-space:nowrap">{{a.CreatedAt | date:'dd MMM, HH:mm:ss'}}</td>
                            <td>{{a.Actor}}</td>
                            <td><strong style="color:#632c76">{{a.Action}}</strong></td>
                            <td>{{a.EntityType}} <span style="color:#888">{{a.EntityRef}}</span></td>
                            <td style="max-width:280px;word-break:break-word;font-size:12px">{{a.Detail}}</td>
                            <td style="font-size:12px;color:#888">{{a.IPAddress}}</td>
                            <td>
                                <span class="sd-badge" data-ng-show="a.Success" style="background:#e8f5e9;color:#2e7d32">OK</span>
                                <span class="sd-badge" data-ng-hide="a.Success" style="background:#fdecea;color:#c62828">Failed</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="auditLogs.length==0" style="text-align:center;padding:30px;color:#aaa">No audit entries yet</div>
            </div>
        </div>

        <!-- LIMS SYNC -->
        <div data-ng-show="activeTab=='lims'">
            <div class="adm-topbar">
                <h2><i class="fa fa-exchange"></i> LIMS Sync</h2>
                <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px"
                        data-ng-click="syncCatalogueNow()" data-ng-disabled="isSyncingCatalogue">
                    <i class="fa fa-refresh" data-ng-class="{'fa-spin': isSyncingCatalogue}"></i> Sync Test Catalogue Now
                </button>
            </div>

            <div class="adm-card" data-ng-show="limsSync">
                <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px" data-ng-show="limsSync.LimsConfigured">
                    <i class="fa fa-check-circle" style="font-size:28px;color:#2e7d32"></i>
                    <div>
                        <div style="font-weight:700;color:#2e7d32">LIMS connection configured</div>
                        <div style="font-size:12px;color:#888">LimsBaseUrl is set — patient/booking/catalogue pushes are live.</div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px" data-ng-hide="limsSync.LimsConfigured">
                    <i class="fa fa-exclamation-triangle" style="font-size:28px;color:#e65100"></i>
                    <div>
                        <div style="font-weight:700;color:#e65100">LIMS not configured</div>
                        <div style="font-size:12px;color:#888">Set LimsBaseUrl in Web.config to start pushing patients, jobs and payments to the LIMS. Until then, everything stays in "Pending".</div>
                    </div>
                </div>

                <div class="adm-stats" style="margin-bottom:0">
                    <div class="stat-card">
                        <div class="stat-num" style="color:#2e7d32">{{limsSync.PatientsSynced}}</div>
                        <div class="stat-label">Patients synced to LIMS</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#e65100">{{limsSync.PatientsPending}}</div>
                        <div class="stat-label">Patients pending sync</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#2e7d32">{{limsSync.BookingsSynced}}</div>
                        <div class="stat-label">Bookings synced (job created)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#e65100">{{limsSync.BookingsPending}}</div>
                        <div class="stat-label">Bookings pending sync</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#c62828">{{limsSync.BookingsFailed}}</div>
                        <div class="stat-label">Bookings failed sync</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num" style="color:#7b1fa2">{{limsSync.TestsNeverSynced}}</div>
                        <div class="stat-label">Test suites never synced</div>
                    </div>
                </div>
                <div style="margin-top:16px;font-size:13px;color:#888">
                    Last catalogue sync:
                    <strong style="color:#222" data-ng-show="limsSync.LastCatalogueSync">{{limsSync.LastCatalogueSync | date:'dd MMM yyyy, HH:mm'}}</strong>
                    <span data-ng-hide="limsSync.LastCatalogueSync">never</span>
                </div>
            </div>

            <!-- Partner/EHR-facing read APIs (Test Catalogue + Report Delivery
                 Phase 4). Set PartnerApiKey in Web.config to enable — these
                 endpoints refuse every request while it's empty (fail closed). -->
            <div class="adm-card">
                <h3><i class="fa fa-plug"></i> Partner API (pricing feed &amp; EHR-facing reports)</h3>
                <p style="font-size:13px;color:#666">Two read-only endpoints for a third-party integration, gated by an <code>X-Api-Key</code> header matching <code>PartnerApiKey</code> in Web.config:</p>
                <table class="adm-table">
                    <thead><tr><th>Endpoint</th><th>Returns</th></tr></thead>
                    <tbody>
                        <tr><td><code>GET /GetPublicCatalogue</code></td><td>Live test/package pricing catalogue</td></tr>
                        <tr><td><code>GET /GetReportsApi/{patientId}</code></td><td>Minimal FHIR-lite <code>DiagnosticReport</code>-shaped list — a starting shape for an EHR integration, not a certified FHIR server</td></tr>
                    </tbody>
                </table>
                <p style="font-size:12px;color:#999;margin-top:10px">Example: <code>curl -H "X-Api-Key: &lt;key&gt;" http://localhost:2091/PathlabService.svc/GetPublicCatalogue</code></p>
            </div>

            <!-- WhatsApp Business Cloud API (Notifications Phase 2 fix) — real
                 automatic sends, not the manual wa.me share links elsewhere on
                 the site. Inert until configured; see WhatsAppHelper.cs. -->
            <div class="adm-card">
                <h3><i class="fa fa-whatsapp" style="color:#25d366"></i> WhatsApp Notifications</h3>
                <p style="font-size:13px;color:#666">Automatic WhatsApp alerts for booking confirmation, status updates and report-ready — separate from the manual "share via WhatsApp" links elsewhere in the portal. Requires a Meta Business Manager WhatsApp account:</p>
                <table class="adm-table">
                    <thead><tr><th>Web.config setting</th><th>What it's for</th></tr></thead>
                    <tbody>
                        <tr><td><code>WhatsAppApiToken</code> / <code>WhatsAppPhoneNumberId</code></td><td>Your Meta Business WhatsApp credentials</td></tr>
                        <tr><td><code>WhatsAppTemplate_BookingConfirmation</code></td><td>Name of a pre-approved template for booking confirmations</td></tr>
                        <tr><td><code>WhatsAppTemplate_StatusUpdate</code></td><td>Name of a pre-approved template for sample-status changes</td></tr>
                        <tr><td><code>WhatsAppTemplate_ReportReady</code></td><td>Name of a pre-approved template for report-ready alerts</td></tr>
                    </tbody>
                </table>
                <p style="font-size:12px;color:#999;margin-top:10px">WhatsApp requires an approved message template for any business-initiated notification (a customer must message first to unlock free-form replies) — these can't be created here, they're approved in Meta Business Manager. Until a template name is set, that event type's WhatsApp send is skipped and logged (never faked) — check Notifications Log, Channel = WhatsApp.</p>
            </div>
        </div>

        <!-- COLLECTION QUEUE (phlebotomist-facing — Sample Collection Phase 3) -->
        <div data-ng-show="activeTab=='queue'">
            <div class="adm-topbar">
                <h2><i class="fa fa-motorcycle"></i> Today's Home Collection Queue</h2>
                <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="setTab('queue')">
                    <i class="fa fa-refresh"></i> Refresh
                </button>
            </div>
            <div class="adm-card">
                <table class="adm-table">
                    <thead>
                        <tr><th>Time Slot</th><th>Sample ID</th><th>Patient</th><th>Phone</th><th>Address</th><th></th></tr>
                    </thead>
                    <tbody>
                        <tr data-ng-repeat="q in collectionQueue">
                            <td><strong style="color:#632c76">{{q.TimeSlot}}</strong></td>
                            <td>{{q.SampleId}}</td>
                            <td>{{q.PatientName}}</td>
                            <td><a href="tel:{{q.PatientPhone}}" style="color:#1565c0">{{q.PatientPhone}}</a></td>
                            <td style="max-width:260px">{{q.Address}}</td>
                            <td>
                                <button data-ng-click="markCollected(q)" style="background:#2e7d32;color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;cursor:pointer">
                                    <i class="fa fa-check"></i> Mark Collected
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="isLoadingQueue" style="text-align:center;padding:30px;color:#632c76"><i class="fa fa-spinner fa-spin fa-2x"></i></div>
                <div data-ng-show="!isLoadingQueue && collectionQueue.length==0" style="text-align:center;padding:30px;color:#aaa">No home collections pending for today.</div>
            </div>
        </div>

        <!-- ANALYTICS (TAT / revenue trend / test volume — Phase 3) -->
        <div data-ng-show="activeTab=='analytics'">
            <div class="adm-topbar">
                <h2><i class="fa fa-bar-chart"></i> Analytics</h2>
                <button style="background:#fff;color:#632c76;border:1px solid #632c76;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="exportAnalyticsCsv()">
                    <i class="fa fa-download"></i> Export CSV
                </button>
            </div>

            <div class="adm-card">
                <div class="adm-date-filter">
                    <div><label>From</label><input type="date" data-ng-model="analyticsFrom"></div>
                    <div><label>To</label><input type="date" data-ng-model="analyticsTo"></div>
                    <button style="background:#632c76;color:#fff;border:none;border-radius:8px;padding:9px 18px;cursor:pointer;font-size:13px" data-ng-click="applyAnalyticsFilter()">Apply</button>
                    <span style="font-size:12px;color:#999">Defaults to the last 30 days when left blank.</span>
                </div>
                <div style="background:#f8f5fc;border-radius:8px;padding:10px 14px;font-size:12px;color:#666;margin-bottom:16px">
                    <i class="fa fa-info-circle"></i> For Power BI/Tableau: point their generic Web/REST connector at
                    <code>GET /GetAnalyticsExport?from=&amp;to=</code> (flat, one row per booking). Full "integration" beyond
                    that means connecting your own Power BI/Tableau workspace — not something this app can set up for you.
                </div>

                <div class="adm-stats" style="margin-bottom:0" data-ng-show="analytics">
                    <div class="stat-card">
                        <div class="stat-num">&#8377;{{analytics.TotalRevenue}}</div>
                        <div class="stat-label">Revenue in range</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num">{{analytics.TotalBookings}}</div>
                        <div class="stat-label">Bookings in range</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-num">{{analytics.AvgTatHours}}h</div>
                        <div class="stat-label">Avg. turnaround time (booking → report ready)</div>
                    </div>
                </div>
            </div>

            <div class="adm-card">
                <h3>Revenue Trend</h3>
                <div class="adm-trend">
                    <div class="adm-trend-bar" data-ng-repeat="d in analytics.DailyTrend">
                        <div class="tip">{{d.Date}}: &#8377;{{d.Revenue}} ({{d.Bookings}} booking{{d.Bookings==1?'':'s'}})</div>
                        <div class="bar" style="height:{{d.barPct}}%"></div>
                    </div>
                </div>
                <div data-ng-show="!analytics.DailyTrend.length" style="text-align:center;padding:20px;color:#aaa">No bookings in this range</div>
                <!-- Table view (accessibility fallback for the bar trend above) -->
                <table class="adm-table" style="margin-top:18px" data-ng-show="analytics.DailyTrend.length">
                    <thead><tr><th>Date</th><th>Bookings</th><th>Revenue</th></tr></thead>
                    <tbody>
                        <tr data-ng-repeat="d in analytics.DailyTrend">
                            <td>{{d.Date}}</td>
                            <td>{{d.Bookings}}</td>
                            <td>&#8377;{{d.Revenue}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="adm-card">
                <h3>Test Volume</h3>
                <table class="adm-table">
                    <thead><tr><th>Test</th><th>Times Booked</th></tr></thead>
                    <tbody>
                        <tr data-ng-repeat="t in analytics.TestVolume">
                            <td><strong style="color:#632c76">{{t.TestSuiteName}}</strong></td>
                            <td>{{t.Count}}</td>
                        </tr>
                    </tbody>
                </table>
                <div data-ng-show="analytics && !analytics.TestVolume.length" style="text-align:center;padding:20px;color:#aaa">No tests booked in this range</div>
            </div>
        </div>

    </div><!-- end adm-content -->
</div><!-- end adm-layout -->
</div><!-- end ng-controller -->
}

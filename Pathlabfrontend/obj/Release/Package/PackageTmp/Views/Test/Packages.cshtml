@{
    ViewBag.Title = "Health Packages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
.pkg-hero{background:linear-gradient(135deg,#4a1060,#1253be);padding:40px 20px;color:#fff;text-align:center}
.pkg-hero h1{font-size:28px;font-weight:800;margin-bottom:8px}
.pkg-hero p{opacity:.85;font-size:15px;max-width:560px;margin:0 auto}
.pkg-grid{max-width:1100px;margin:36px auto;padding:0 16px;display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:24px}
.pkg-card{background:#fff;border:1px solid #e8e0f0;border-radius:18px;overflow:hidden;box-shadow:0 4px 18px rgba(99,44,118,.08);transition:transform .25s,box-shadow .25s}
.pkg-card:hover{transform:translateY(-4px);box-shadow:0 8px 32px rgba(99,44,118,.15)}
.pkg-card-top{background:linear-gradient(135deg,#632c76,#1253be);padding:24px;color:#fff;position:relative}
.pkg-badge{position:absolute;top:14px;right:14px;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.pkg-card-top h3{font-size:20px;font-weight:700;margin-bottom:6px}
.pkg-card-top .pkg-count{font-size:13px;opacity:.85}
.pkg-card-body{padding:20px}
.pkg-test-list{list-style:none;padding:0;margin:0 0 16px}
.pkg-test-list li{font-size:13px;color:#555;padding:5px 0;border-bottom:1px solid #f5f0fa;display:flex;align-items:center;gap:8px}
.pkg-test-list li:before{content:'✓';color:#51ca62;font-weight:700;font-size:14px}
.pkg-price-row{display:flex;justify-content:space-between;align-items:center;padding-top:14px;border-top:1px solid #f0e8f0}
.pkg-price{font-size:22px;font-weight:800;color:#632c76}
.pkg-book-btn{background:#632c76;color:#fff;border:none;border-radius:35px 0 35px 35px;padding:11px 24px;font-size:14px;font-weight:700;cursor:pointer;transition:background .3s;text-decoration:none;display:inline-block}
.pkg-book-btn:hover{background:#1253be}
.pkg-savings{font-size:12px;color:#2e7d32;font-weight:600;margin-top:4px}
.pkg-spinner{text-align:center;padding:60px;color:#632c76}
</style>
}

<div data-ng-controller="PackagesController">

<div class="pkg-hero">
    <h1><i class="fa fa-medkit"></i> Health Packages</h1>
    <p>Comprehensive health checkup packages designed for your well-being at affordable prices</p>
</div>

<div class="pkg-spinner" data-ng-show="isLoading">
    <i class="fa fa-spinner fa-spin fa-3x"></i><p>Loading packages...</p>
</div>

<div class="pkg-grid" data-ng-show="!isLoading">
    <div class="pkg-card" data-ng-repeat="p in packages">
        <div class="pkg-card-top">
            <span class="pkg-badge" data-ng-show="p.Badge">{{p.Badge}}</span>
            <h3>{{p.PackageName}}</h3>
            <div class="pkg-count"><i class="fa fa-flask"></i> {{p.TestCount}} Tests Included</div>
        </div>
        <div class="pkg-card-body">
            <ul class="pkg-test-list">
                <li data-ng-repeat="t in p.Tests | limitTo:6">{{t}}</li>
                <li data-ng-show="p.Tests.length > 6" style="color:#632c76;font-weight:600;cursor:pointer" data-ng-click="p.showAll=!p.showAll">
                    {{p.showAll ? '- Show Less' : '+ '+(p.Tests.length-6)+' more tests'}}
                </li>
                <li data-ng-show="p.showAll" data-ng-repeat="t in p.Tests | limitTo:999 | sliceFrom:6">{{t}}</li>
            </ul>
            <div class="pkg-price-row">
                <div>
                    <div class="pkg-price">&#8377;{{p.Price}}</div>
                    <div class="pkg-savings" data-ng-show="p.OriginalPrice && p.OriginalPrice > p.Price">
                        <i class="fa fa-tag"></i> Save &#8377;{{p.OriginalPrice - p.Price}}
                    </div>
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                    <a class="pkg-book-btn" style="background:#fff;color:#632c76;border:1.5px solid #632c76" data-ng-href="/Test/PackageDetail/{{p.PackageId}}">
                        Know More
                    </a>
                    <button class="pkg-book-btn" data-ng-click="bookPackage(p)">
                        <i class="fa fa-calendar-plus-o"></i> Book Now
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div data-ng-show="!isLoading && packages.length==0" style="text-align:center;padding:60px;color:#aaa">
    <i class="fa fa-medkit fa-3x" style="display:block;margin-bottom:12px"></i>
    <p>No packages available at the moment.</p>
</div>

</div>

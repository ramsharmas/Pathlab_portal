@{
    ViewBag.Title = "Your Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
.cart-wrap{max-width:860px;margin:40px auto 60px;padding:0 20px}
.cart-breadcrumb{margin-bottom:24px;font-size:13px;color:#888}
.cart-breadcrumb a{color:#632c76;text-decoration:none}
.cart-breadcrumb a:hover{text-decoration:underline}
.cart-heading{font-size:28px;font-weight:700;color:#632c76;margin-bottom:28px;display:flex;align-items:center;gap:10px}
.cart-heading i{font-size:26px}
.cart-card{background:#fff;border:1px solid #e8e0f0;border-radius:16px;padding:28px 32px;box-shadow:0 2px 12px rgba(99,44,118,.06);margin-bottom:24px}
.cart-item-row{display:flex;align-items:flex-start;justify-content:space-between;padding:16px 0;border-bottom:1px solid #f0ecfa;gap:12px}
.cart-item-row:last-child{border-bottom:none}
.cart-item-name{font-size:16px;font-weight:600;color:#222;margin-bottom:4px}
.cart-item-meta{font-size:13px;color:#888}
.cart-item-right{display:flex;align-items:center;gap:12px;flex-shrink:0}
.cart-item-price{font-size:18px;font-weight:700;color:#632c76;white-space:nowrap}
.cart-remove-btn{background:none;border:none;color:#e53e3e;cursor:pointer;font-size:20px;padding:4px 6px;border-radius:6px;transition:background .2s;line-height:1}
.cart-remove-btn:hover{background:#fff0f0}
.cart-empty-box{text-align:center;padding:60px 20px;color:#aaa}
.cart-empty-box i{font-size:64px;display:block;margin-bottom:16px;color:#ddd}
.cart-empty-box p{font-size:16px;margin-bottom:20px}
.cart-summary-box{background:#f8f5fc;border-radius:12px;padding:20px;margin-top:4px}
.cart-summary-row{display:flex;justify-content:space-between;font-size:14px;color:#555;margin-bottom:10px}
.cart-summary-row.total{font-size:20px;font-weight:700;color:#632c76;border-top:1px solid #ddd;padding-top:12px;margin-top:4px}
.cart-actions{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;margin-top:8px}
.cart-add-more{display:inline-flex;align-items:center;gap:8px;font-size:15px;font-weight:600;color:#632c76;text-decoration:none;padding:12px 20px;border:2px solid #632c76;border-radius:35px 0 35px 35px;transition:all .2s}
.cart-add-more:hover{background:#f5f0fa}
.cart-proceed-btn{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;background:#632c76;color:#fff;border:none;border-radius:35px 0 35px 35px;font-size:17px;font-weight:700;cursor:pointer;letter-spacing:1px;transition:background .3s}
.cart-proceed-btn:hover{background:#1253be}
.sd-toast{position:fixed;bottom:24px;right:24px;z-index:999999;background:#632c76;color:#fff;padding:14px 22px;border-radius:10px;font-size:15px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,.25);transform:translateY(100px);opacity:0;transition:all .35s ease;pointer-events:none;max-width:340px}
.sd-toast.show{transform:translateY(0);opacity:1}
.sd-toast.success{background:#2e7d32}
.sd-toast.error{background:#c62828}
.cart-count-chip{display:inline-flex;align-items:center;justify-content:center;background:#632c76;color:#fff;border-radius:20px;padding:3px 12px;font-size:13px;font-weight:700;margin-left:8px}
.cart-note{background:#e8f5e9;border:1px solid #a5d6a7;border-radius:10px;padding:12px 16px;font-size:13px;color:#2e7d32;display:flex;align-items:center;gap:10px;margin-top:16px}
.cart-note i{font-size:16px;flex-shrink:0}
@@media(max-width:600px){.cart-card{padding:20px 16px}.cart-proceed-btn{width:100%;justify-content:center}.cart-actions{flex-direction:column}.cart-add-more{width:100%;justify-content:center}}
</style>
}

<div class="sd-toast" id="sdToast"></div>

<!-- ===== BANNER ===== -->
<div class="banner-outer">
  <div class="banner-box">
    <img src="@Url.Content("~/images/pathology-test-banner.png")" alt="Your Cart – Swapnil Diagnostics">
  </div>
</div>

<!-- ===== MAIN CONTENT ===== -->
<div class="inner-page-section why-section">
  <div class="wrapper clearfix">
    <div class="cart-wrap">
      <div class="cart-breadcrumb">
        <a href="@Url.Action("Index","Home")">Home</a> &gt; <a href="@Url.Action("BookTest","Test")">Book a Test</a> &gt; <span>Your Cart</span>
      </div>

      <div class="cart-heading">
        <i class="fa fa-shopping-cart"></i>
        Your Cart <span class="cart-count-chip" id="cartCountChip">0</span>
      </div>

      <!-- Cart items card -->
      <div class="cart-card" id="cartCard">
        <div id="cartItemsWrap">
          <!-- Items injected by JS -->
        </div>

        <!-- Empty state -->
        <div class="cart-empty-box" id="cartEmpty" style="display:none">
          <i class="fa fa-flask"></i>
          <p>Your cart is empty.</p>
          <a href="@Url.Action("BookTest","Test")" class="cart-proceed-btn" style="text-decoration:none;font-size:15px;padding:12px 28px">
            <i class="fa fa-plus"></i>&nbsp; Add Tests
          </a>
        </div>

        <!-- Summary -->
        <div id="cartSummaryWrap" style="display:none">
          <div class="cart-summary-box">
            <div class="cart-summary-row"><span>Subtotal</span><span id="cartSubtotal">₹0</span></div>
            <div class="cart-summary-row"><span>GST (18%)</span><span id="cartGst">₹0</span></div>
            <div class="cart-summary-row total"><span>Total Payable</span><span id="cartTotal">₹0</span></div>
          </div>
          <div class="cart-note">
            <i class="fa fa-info-circle"></i>
            Cart is saved automatically. You can safely go back and add more tests.
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="cart-actions" id="cartActionsWrap" style="display:none">
        <a href="@Url.Action("BookTest","Test")" class="cart-add-more">
          <i class="fa fa-plus-circle"></i>&nbsp; Add More Tests
        </a>
        <button class="cart-proceed-btn" onclick="proceedToCheckout()">
          <i class="fa fa-arrow-right"></i>&nbsp; Proceed to Checkout
        </button>
      </div>
    </div>
  </div>
</div>

@section scripts {
<script>
function esc(s){ if(s==null) return ''; const d=document.createElement('div'); d.textContent=String(s); return d.innerHTML; }
function showToast(msg, type){
  const t=document.getElementById('sdToast');
  t.textContent=msg; t.className='sd-toast '+(type||'');
  setTimeout(()=>t.classList.add('show'),10);
  setTimeout(()=>t.classList.remove('show'),3200);
}

let cart = JSON.parse(sessionStorage.getItem('sd_cart')||'[]');

function renderCart(){
  const wrap = document.getElementById('cartItemsWrap');
  const empty = document.getElementById('cartEmpty');
  const summary = document.getElementById('cartSummaryWrap');
  const actions = document.getElementById('cartActionsWrap');
  const chip = document.getElementById('cartCountChip');

  chip.textContent = cart.length;

  if(cart.length === 0){
    wrap.innerHTML = '';
    empty.style.display = 'block';
    summary.style.display = 'none';
    actions.style.display = 'none';
    return;
  }

  empty.style.display = 'none';
  summary.style.display = 'block';
  actions.style.display = 'flex';

  wrap.innerHTML = cart.map(item => `
    <div class="cart-item-row" id="row-${esc(item.TestSuiteID)}">
      <div>
        <div class="cart-item-name">${esc(item.TestSuiteName)}</div>
        <div class="cart-item-meta">
          <i class="fa fa-tint" style="color:#632c76"></i>&nbsp; ${esc(item.SampleType)}
          &nbsp;&nbsp;|&nbsp;&nbsp;
          <i class="fa fa-list-ol" style="color:#632c76"></i>&nbsp; ${item.TestCount} Parameter${item.TestCount!==1?'s':''}
          ${item.FastingRequired ? '&nbsp;&nbsp;|&nbsp;&nbsp;<i class="fa fa-clock-o" style="color:#e65100"></i>&nbsp; <span style="color:#e65100;font-weight:600">Fasting required</span>' : ''}
        </div>
      </div>
      <div class="cart-item-right">
        <span class="cart-item-price">&#8377;${item.Price.toLocaleString('en-IN')}</span>
        <button class="cart-remove-btn" onclick="removeItem('${esc(item.TestSuiteID)}')" title="Remove">
          <i class="fa fa-times-circle"></i>
        </button>
      </div>
    </div>`).join('');

  const sub = cart.reduce((s,i)=>s+i.Price, 0);
  const gst = Math.round(sub * 0.18);
  document.getElementById('cartSubtotal').textContent = '₹'+sub.toLocaleString('en-IN');
  document.getElementById('cartGst').textContent = '₹'+gst.toLocaleString('en-IN');
  document.getElementById('cartTotal').textContent = '₹'+(sub+gst).toLocaleString('en-IN');
}

function removeItem(id){
  cart = cart.filter(i => i.TestSuiteID !== id);
  sessionStorage.setItem('sd_cart', JSON.stringify(cart));
  renderCart();
  showToast('Test removed from cart.', 'error');
}

function proceedToCheckout(){
  if(cart.length === 0){ showToast('Your cart is empty.', 'error'); return; }
  const user = JSON.parse(localStorage.getItem('sd_user')||'null');
  if(!user){
    window.location.href = '@Url.Action("Login","Account")?next=@Url.Action("ChooseCollection","Booking")';
  } else {
    window.location.href = '@Url.Action("ChooseCollection","Booking")';
  }
}

renderCart();
</script>
}

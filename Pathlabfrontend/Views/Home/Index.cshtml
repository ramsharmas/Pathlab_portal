@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div data-ng-controller="HomeController">

<!--=============== HOME COLLECTION LEAD POPUP ======================-->
<style>[data-ng-cloak]{display:none !important}</style>
<div class="start-popup" data-ng-cloak data-ng-show="showLeadPopup">
    <div class="popup-innner-box clearfix">
        <span class="cross" data-ng-click="closeLeadPopup()">X</span>
        <div class="start-popup-left">
            <img src="@Url.Content("~/images/lead-form-popup-bg-desk.png")" alt="Book Free Home Collection">
        </div>
        <div class="start-popup-right" data-ng-hide="leadDone">
            <h5>Book Free Home Collection Today!</h5>
            <div class="fild-box full-length">
                <label>Full Name*</label>
                <input type="text" placeholder="Enter your first and last Name" data-ng-model="lead.name">
            </div>
            <div class="fild-box full-length">
                <label>Mobile Number</label>
                <input type="tel" maxlength="10" placeholder="Enter 10 digit mobile number" data-ng-model="lead.mobile">
            </div>
            <div class="fild-box full-length">
                <label>City</label>
                <select data-ng-model="lead.city">
                    <option>Bhopal</option>
                    <option>Indore</option>
                    <option>Jabalpur</option>
                    <option>Gwalior</option>
                </select>
            </div>
            <div class="fild-box full-length" style="color:#e53e3e;font-size:14px" data-ng-show="leadError">{{leadError}}</div>
            <div class="fild-box full-length">
                <button class="btn" data-ng-click="submitLead()">SUBMIT</button>
            </div>
        </div>
        <div class="start-popup-right" data-ng-show="leadDone">
            <h5>Thank You!</h5>
            <p style="font-size:16px;color:#555">Our team will contact you shortly to schedule your free home sample collection.</p>
            <p style="font-size:14px;color:#888;margin-top:14px">Want to book right away?</p>
            <a href="@Url.Action("BookTest","Test")" class="btn" style="display:inline-block;margin-top:10px">Book a Test Now</a>
        </div>
    </div>
</div>

<!--=============== BANNER SECTION ======================-->
<div class="banner-outer">
    <div class="banner-box">
        <div class="regular slider">
            <div><a href="@Url.Action("BookTest","Test")"><img src="@Url.Content("~/images/banner2.png")" alt="Book a Test"></a></div>
            <div><a href="@Url.Action("BookTest","Test")"><img src="@Url.Content("~/images/banner1.png")" alt="Book a Test"></a></div>
            <div><a href="@Url.Action("BookTest","Test")"><img src="@Url.Content("~/images/banner3.png")" alt="Book a Test"></a></div>
        </div>
    </div>
</div>

<!--=============== BODY SECTION ======================-->
<div class="home-page">

<!--=============== FEATURE SECTION ======================-->
<div class="feature-outer">

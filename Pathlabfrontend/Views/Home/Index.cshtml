                    <div class="feature-icon"><img src="@Url.Content("~/images/pillar-1.png")"></div>
                    <div class="feature-text">
                        <h4>Best in class customer experience</h4>
                        <p style="display:block;">Re-imagine and transform the journey for all our stakeholders by addressing the key pain points and bringing a differentiated service proposition</p>
                    </div>
                </div>
                <div class="feature-details">
                    <div class="feature-icon"><img src="@Url.Content("~/images/pillar-2.png")"></div>
                    <div class="feature-text">
                        <h4>Digital first with an analytics powerhouse</h4>
                        <p>Create a platform that supports end to end digital journey</p>
                    </div>
                </div>
                <div class="feature-details">
                    <div class="feature-icon"><img src="@Url.Content("~/images/pillar-3.png")"></div>
                    <div class="feature-text">
                        <h4>Science led proposition for doctors</h4>
                        <p>Partner with doctors to shape the diagnostic guidelines through a science led approach</p>
                    </div>
                </div>
                <div class="feature-details">
                    <div class="feature-icon"><img src="@Url.Content("~/images/pillar-4.png")"></div>
                    <div class="feature-text">
                        <h4>Best in class customer experience</h4>
                        <p>Lead with best-in-class quality standards to cement strong trust with our stakeholders</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="feature-box-right">
            <img src="@Url.Content("~/images/green-lupin-flower.png")">
        </div>
    </div>
</div>

<!--=============== HOME COLLECTION SECTION ======================-->
<div class="home-colletion">
    <div class="wrapper-home-right">
        <div class="title-box">
            <h2>Reliable and Safe Home Collection</h2>
            <p class="sub">For the first time in India, temperature-controlled sample movement &amp; tracking for best quality result. Experience safe &amp; convenient home collection by experts using the latest technology.</p>
        </div>
        <div class="home-collection-outer clearfix">
            <div class="home-collection-box">
                <div class="collection-pic"><img src="@Url.Content("~/images/step2.png")"></div>
                <h4>Guaranteed time slots</h4>
            </div>
            <div class="home-collection-box">
                <div class="collection-pic"><img src="@Url.Content("~/images/step3.png")"></div>
                <h4>Temperature control sample movement and tracking</h4>
            </div>
            <div class="home-collection-box">
                <div class="collection-pic"><img src="@Url.Content("~/images/step1.png")"></div>
                <h4>Personalised sample collection kit</h4>
            </div>
            <div class="home-collection-box">
                <div class="collection-pic"><img src="@Url.Content("~/images/step4.png")"></div>
                <h4>Free home sample collection*</h4>
            </div>
        </div>
        <a href="@Url.Action("BookTest","Test")" class="white-btn">Book Home Collection</a>
    </div>
</div>

<!--=============== MOST BOOKED TESTS ======================-->
<!-- Cards come from the unified test catalogue (LIMS SetupTestsuite mapping):
     name = TestSuiteName, parameters = TestCount, plus website-side Price,
     Description and TestType badge (Test / Package). -->
<script src="@Url.Content("~/Scripts/lims-api.js")"></script>
<div class="book-test-section">
    <div class="wrapper-home clearfix">
        <div class="book-test-inner">
            <div class="title-box">
                <h2>Most Booked Tests</h2>
                <p>Preventive, routine, specialised tests so that your health is on track.</p>
            </div>
        </div>
        <div class="test-package-details" style="display:block;">
            <div class="center-box-outer clearfix">
                <div class="center-box center-box-two" data-ng-repeat="item in featuredCatalogue">
                    <div class="center-head">
                        <h3>{{item.TestSuiteName}} <span>&#8377;{{item.Price}}</span></h3>
                        <span style="display:inline-block;margin-top:4px;padding:2px 10px;border-radius:10px;font-size:11px;font-weight:600;color:#fff" data-ng-style="{background: item.TestType === 'Package' ? '#e65100' : '#632c76'}">{{item.TestType || 'Test'}}</span>
                    </div>
                    <div class="include">
                        <p>Includes<br>{{item.TestCount}} Test Parameter(s)</p>
                        <p>{{(item.Description || item.TestSuiteName) | limitTo:90}}{{(item.Description || '').length > 90 ? '…' : ''}} <a href="@Url.Action("BookTest","Test")">Read more</a></p>
                    </div>
                    <div class="center-box-btn clearfix">
                        <a href="@Url.Action("BookTest","Test")">Know more</a>
                        <a href="javascript:void(0)" data-ng-click="addToCart(item)" class="book-btn" title="Add to Cart"><i class="fa fa-cart-arrow-down"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="btn-box">
            <a href="@Url.Action("BookTest","Test")" class="btn">View All Test</a>
        </div>
    </div>
</div>


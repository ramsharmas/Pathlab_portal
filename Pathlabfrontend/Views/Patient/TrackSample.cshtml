@{
    ViewBag.Title = "Track My Sample";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
.track-hero{background:linear-gradient(135deg,#4a1060,#1253be);padding:40px 20px;color:#fff;text-align:center}
.track-hero h1{font-size:28px;font-weight:800;margin-bottom:8px}
.track-wrap{max-width:680px;margin:40px auto;padding:0 20px}
.track-box{background:#fff;border:1px solid #e8e0f0;border-radius:18px;padding:36px;box-shadow:0 4px 24px rgba(99,44,118,.09)}
.track-input-row{display:flex;gap:12px;margin-bottom:8px}
.track-input-row input{flex:1;padding:14px 18px;border:2px solid #ddd;border-radius:10px;font-size:16px;font-family:inherit;transition:border .2s}
.track-input-row input:focus{border-color:#632c76;outline:none}
.track-btn{background:#632c76;color:#fff;border:none;border-radius:35px 0 35px 35px;padding:14px 28px;font-size:16px;font-weight:700;cursor:pointer;transition:background .3s;white-space:nowrap}
.track-btn:hover{background:#1253be}
.track-result{margin-top:28px}
.track-result-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:24px}
.track-ref{font-size:20px;font-weight:800;color:#632c76}
.track-status-badge{padding:7px 18px;border-radius:24px;font-size:14px;font-weight:700}
.status-booked{background:#e3f2fd;color:#1565c0}
.status-confirmed{background:#e8f5e9;color:#2e7d32}
.status-processing{background:#f3e5f5;color:#7b1fa2}
.status-ready{background:#e0f7fa;color:#00695c}
.track-steps{display:flex;align-items:flex-start;gap:0;margin:28px 0}
.track-step{flex:1;text-align:center;position:relative}
.track-step:not(:last-child):after{content:'';position:absolute;top:20px;left:60%;width:80%;height:2px;background:#ddd;z-index:0}
.track-step:not(:last-child).done:after{background:#51ca62}
.track-dot{width:40px;height:40px;border-radius:50%;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;position:relative;z-index:1;border:2px solid #ddd;background:#fff;color:#aaa;transition:all .4s}
.track-step.done .track-dot{background:#51ca62;border-color:#51ca62;color:#fff}
.track-step.active .track-dot{background:#632c76;border-color:#632c76;color:#fff}
.track-step-label{font-size:12px;font-weight:600;color:#888}
.track-step.done .track-step-label,.track-step.active .track-step-label{color:#222}
.track-info{background:#f8f5fc;border-radius:12px;padding:18px;margin-top:8px}
.track-info-row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #ede8f5;font-size:14px;color:#555}
.track-info-row:last-child{border-bottom:none}
.track-info-row strong{color:#222}
.track-error{background:#fff3f3;border:1px solid #ffcdd2;border-radius:10px;padding:16px;text-align:center;color:#c62828;font-size:14px;font-weight:600;margin-top:20px}
.track-spinner{text-align:center;padding:32px;color:#632c76}
.track-sample-card{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;background:#fff;border:1px dashed #b79cc7;border-radius:12px;padding:16px 18px;margin-bottom:20px}
.track-sample-id{font-size:18px;font-weight:800;color:#222;letter-spacing:1px}
.track-sample-meta{font-size:12px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.track-barcode{display:flex;align-items:stretch;height:42px}
.track-barcode span{background:#222}
.track-barcode-num{font-family:monospace;font-size:13px;letter-spacing:3px;color:#222;text-align:center;margin-top:4px}
.track-live{font-size:12px;color:#888;text-align:right;margin-top:10px}
.track-live .dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:#51ca62;margin-right:5px;animation:trackPulse 1.6s infinite}
@@keyframes trackPulse{0%,100%{opacity:1}50%{opacity:.35}}
.track-timeline{margin-top:20px;border-top:1px solid #ede8f5;padding-top:16px}
.track-timeline h4{font-size:14px;color:#632c76;margin-bottom:12px}
.track-tl-item{display:flex;gap:12px;padding:6px 0}
.track-tl-dot{width:12px;height:12px;border-radius:50%;background:#51ca62;margin-top:4px;flex-shrink:0}
.track-tl-item:last-child .track-tl-dot{background:#632c76}
.track-tl-body{font-size:13px;color:#555}
.track-tl-body strong{color:#222;display:block}
.track-tl-time{font-size:12px;color:#999;margin-left:auto;white-space:nowrap}
</style>
}

<div data-ng-controller="TrackSampleController">

<div class="track-hero">
    <h1><i class="fa fa-map-marker"></i> Track My Sample</h1>
    <p style="opacity:.85;font-size:15px;max-width:520px;margin:0 auto">Enter your booking reference number to get real-time status of your sample</p>
</div>

<div class="track-wrap">
    <div class="track-box">
        <h3 style="font-size:18px;color:#222;margin-bottom:16px">Enter Booking Reference</h3>
        <div class="track-input-row">
            <input type="text" placeholder="e.g. BK1234567890" data-ng-model="refInput" data-ng-keypress="($event.which==13) && trackSample()">
            <button class="track-btn" data-ng-click="trackSample()">
                <i class="fa fa-search"></i> Track
            </button>
        </div>

        <div class="track-spinner" data-ng-show="isLoading">
            <i class="fa fa-spinner fa-spin fa-2x"></i><p>Fetching status...</p>
        </div>

        <div class="track-error" data-ng-show="!isLoading && errorMsg">
            <i class="fa fa-exclamation-triangle"></i> {{errorMsg}}
        </div>

        <div class="track-result" data-ng-show="!isLoading && booking">
            <div class="track-result-header">
                <div>
                    <div style="font-size:12px;color:#888;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Booking Reference</div>
                    <div class="track-ref">{{booking.BookingRef}}</div>
                </div>
                <span class="track-status-badge status-{{booking.BookingStatus.toLowerCase()}}">{{booking.BookingStatus}}</span>
            </div>

            <!-- Sample identity (generated at booking; barcode label is printed by the lab) -->
            <div class="track-sample-card" data-ng-show="booking.SampleId">
                <div>
                    <div class="track-sample-meta">Sample ID</div>
                    <div class="track-sample-id">{{booking.SampleId}}</div>
                    <div style="font-size:12px;color:#888;margin-top:4px">
                        LIMS Job: <strong style="color:#632c76">{{booking.LimsJobId || 'sync pending'}}</strong>
                    </div>
                </div>
                <div data-ng-show="booking.Barcode">
                    <div class="track-barcode">
                        <span data-ng-repeat="bar in barcodeBars track by $index"
                              style="width:{{bar.w}}px;margin-right:{{bar.gap}}px"></span>
                    </div>
                    <div class="track-barcode-num">{{booking.Barcode}}</div>
                </div>
            </div>

            <!-- Progress Steps -->
            <div class="track-steps">
                <div class="track-step" data-ng-class="getStepClass(0)">
                    <div class="track-dot"><i class="fa fa-check" data-ng-show="stepIndex > 0"></i><span data-ng-show="stepIndex <= 0">1</span></div>
                    <div class="track-step-label">Booked</div>
                </div>
                <div class="track-step" data-ng-class="getStepClass(1)">
                    <div class="track-dot"><i class="fa fa-check" data-ng-show="stepIndex > 1"></i><span data-ng-show="stepIndex <= 1">2</span></div>
                    <div class="track-step-label">Sample<br>Collected</div>
                </div>
                <div class="track-step" data-ng-class="getStepClass(2)">
                    <div class="track-dot"><i class="fa fa-check" data-ng-show="stepIndex > 2"></i><span data-ng-show="stepIndex <= 2">3</span></div>
                    <div class="track-step-label">At Lab</div>
                </div>
                <div class="track-step" data-ng-class="getStepClass(3)">
                    <div class="track-dot"><i class="fa fa-check" data-ng-show="stepIndex > 3"></i><span data-ng-show="stepIndex <= 3">4</span></div>
                    <div class="track-step-label">Processing</div>
                </div>
                <div class="track-step" data-ng-class="getStepClass(4)">
                    <div class="track-dot"><i class="fa fa-check" data-ng-show="stepIndex >= 4"></i><span data-ng-show="stepIndex < 4">5</span></div>
                    <div class="track-step-label">Report Ready</div>
                </div>
            </div>

            <div class="track-live" data-ng-show="lastRefreshed">
                <span class="dot"></span>Live — status refreshes automatically. Last updated {{lastRefreshed | date:'HH:mm:ss'}}
            </div>

            <!-- Booking Details -->
            <div class="track-info">
                <div class="track-info-row"><span>Patient Name</span><strong>{{booking.PatientName}}</strong></div>
                <div class="track-info-row"><span>Phone</span><strong>{{booking.PatientPhone}}</strong></div>
                <div class="track-info-row"><span>Tests</span><strong>{{booking.Tests.length}} test(s)</strong></div>
                <div class="track-info-row"><span>Collection</span><strong style="text-transform:capitalize">{{booking.CollectionType}}</strong></div>
                <div class="track-info-row" data-ng-show="booking.CollectionDate"><span>Collection Date</span><strong>{{booking.CollectionDate | date:'dd MMM yyyy'}}</strong></div>
                <div class="track-info-row" data-ng-show="booking.TimeSlot"><span>Time Slot</span><strong>{{booking.TimeSlot}}</strong></div>
                <div class="track-info-row" data-ng-show="booking.CollectionType=='home'"><span>Phlebotomist</span><strong>{{phleb(booking).name}} ({{phleb(booking).phone}})</strong></div>
                <div class="track-info-row" data-ng-show="booking.CollectionType=='home' && stepIndex<1"><span>Expected Arrival</span><strong>{{booking.TimeSlot}} on {{booking.CollectionDate | date:'dd MMM yyyy'}}</strong></div>
                <div class="track-info-row"><span>Total Amount</span><strong>&#8377;{{booking.TotalAmount}}</strong></div>
            </div>

            <!-- Status timeline from SampleStatusHistory -->
            <div class="track-timeline" data-ng-show="timeline.Events.length">
                <h4><i class="fa fa-history"></i> Status Timeline</h4>
                <div class="track-tl-item" data-ng-repeat="ev in timeline.Events">
                    <div class="track-tl-dot"></div>
                    <div class="track-tl-body">
                        <strong>{{ev.StatusLabel}}</strong>
                        <span data-ng-show="ev.Notes">{{ev.Notes}}</span>
                    </div>
                    <div class="track-tl-time">{{ev.CreatedAt | date:'dd MMM, HH:mm'}}</div>
                </div>
            </div>

            <!-- Chain of custody (Sample Collection Phase 4) — a finer-grained
                 handoff record than the status timeline above; only appears once
                 staff have actually logged a handoff. -->
            <div class="track-timeline" data-ng-show="custody.Events.length">
                <h4><i class="fa fa-exchange"></i> Chain of Custody</h4>
                <div class="track-tl-item" data-ng-repeat="ev in custody.Events">
                    <div class="track-tl-dot"></div>
                    <div class="track-tl-body">
                        <strong>{{ev.Action}}</strong>
                        <span>{{ev.HandlerName}} ({{ev.HandlerRole}})<span data-ng-show="ev.Location"> — {{ev.Location}}</span></span>
                    </div>
                    <div class="track-tl-time">{{ev.CreatedAt | date:'dd MMM, HH:mm'}}</div>
                </div>
            </div>

            <div data-ng-show="booking.BookingStatus=='Ready'" style="background:#e8f5e9;border-radius:10px;padding:16px;margin-top:16px;text-align:center">
                <i class="fa fa-check-circle" style="color:#2e7d32;font-size:28px;display:block;margin-bottom:8px"></i>
                <strong style="color:#2e7d32">Your report is ready!</strong>
                <p style="color:#555;margin:8px 0 0;font-size:14px">Please visit the lab or login to your portal to download.</p>
                <a href="@Url.Action("Portal","Patient")?tab=reports" style="display:inline-block;margin-top:12px;padding:10px 24px;background:#2e7d32;color:#fff;border-radius:35px 0 35px 35px;text-decoration:none;font-weight:700;font-size:14px">
                    <i class="fa fa-download"></i> Download Report
                </a>
            </div>
        </div>
    </div>
</div>

<div class="sd-toast" id="sdToast"></div>

</div>
